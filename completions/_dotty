#compdef dotty

# Zsh completion for dotty - a dotfiles manager

_dotty_registry_names() {
    local registry="${DOTTY_DIR:-$HOME/.dotty}/registry"
    [[ -f "$registry" ]] || return
    local -a names
    while IFS='=' read -r name _; do
        [[ -n "$name" ]] && names+=("$name")
    done < "$registry"
    compadd -a names
}

_dotty_custom_command_names() {
    local -a names
    names=("${(@f)$(command dotty commands 2>/dev/null | awk '{print $1}')}")
    [[ ${#names[@]} -gt 0 ]] || return
    compadd -a names
}

_dotty() {
    local -a commands=(
        'install:Resolve chain, clone deps, link files, run hooks'
        'update:Pull dotty and all repos, re-link, re-run hooks'
        'commands:List repo-defined commands from the active chain'
        'run:Run a repo-defined command from .dotty/commands/'
        'self-update:Update dotty itself'
        'add:Move a dotfile into a repo and symlink it back'
        'link:Re-create symlinks only (skip pull and hooks)'
        'uninstall:Remove a repo'\''s symlinks, restore backups, unregister'
        'status:Show repos, chain order, environment, and link health'
        'register:Register an already-cloned repo'
        'unregister:Remove a repo from the registry'
        'files:List all managed files, grouped by repo'
        'trace:Show which repo a file or directory comes from'
        'doctor:Check registry, chain, hooks, and repo commands'
        'check:Warn if repos haven'\''t been fetched recently'
        'shell-init:Output shell wrapper for auto-reload after changes'
        'guard:Install pre-commit hook to block sensitive content'
        'unguard:Remove the dotty pre-commit hook'
        'help:Show help'
        'version:Show version'
    )

    local -a global_opts=(
        '-v[Show per-file messages]'
        '--verbose[Show per-file messages]'
        '-n[Preview changes without modifying the filesystem]'
        '--dry-run[Preview changes without modifying the filesystem]'
    )

    if (( CURRENT == 2 )); then
        _describe -t commands 'dotty command' commands
        _arguments -s $global_opts
        return
    fi

    case "${words[2]}" in
        install)
            _files -/
            ;;
        update|link|uninstall|unregister|files)
            _dotty_registry_names
            ;;
        add)
            # Handle --repo flag
            if [[ "${words[CURRENT-1]}" == "--repo" ]]; then
                _dotty_registry_names
            else
                _arguments \
                    '--repo[Target repo]:repo name:_dotty_registry_names' \
                    '*:file:_files'
            fi
            ;;
        run)
            if (( CURRENT == 3 )); then
                _dotty_custom_command_names
            fi
            ;;
        register)
            if (( CURRENT == 3 )); then
                _files -/
            fi
            ;;
        trace)
            _files
            ;;
        guard|unguard)
            _files -/
            ;;
        commands|self-update|shell-init|doctor|check)
            ;;
    esac
}

_dotty "$@"
