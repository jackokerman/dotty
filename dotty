#!/usr/bin/env bash
# dotty - a dotfiles manager with overlay semantics
{

set -euo pipefail

DOTTY_VERSION="0.3.0"
DOTTY_DIR="${DOTTY_DIR:-$HOME/.dotty}"
DOTTY_REGISTRY="$DOTTY_DIR/registry"
DOTTY_REPOS_DIR="$DOTTY_DIR/repos"
DOTTY_BACKUPS_DIR="$DOTTY_DIR/backups"
DOTTY_CLEANUPS_DIR="$DOTTY_DIR/cleanups"
DOTTY_VERBOSE="${DOTTY_VERBOSE:-false}"
DOTTY_DRY_RUN="${DOTTY_DRY_RUN:-false}"
_DOTTY_CHANGES_MADE=false
_DOTTY_OPERATION_LOCK_DIR=""
_DOTTY_OPERATION_LOCK_PID=""

# shellcheck source=lib/utils.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/utils.sh"

# Registry

registry_init() {
    mkdir -p "$DOTTY_DIR" "$DOTTY_REPOS_DIR" "$DOTTY_BACKUPS_DIR" "$DOTTY_CLEANUPS_DIR"
    touch "$DOTTY_REGISTRY"
}

registry_get() {
    local name="$1"
    local line
    line="$(grep -m1 "^${name}=" "$DOTTY_REGISTRY" 2>/dev/null)" || return 1
    echo "${line#*=}"
}

registry_set() {
    local name="$1"
    local path="$2"

    if grep -q "^${name}=" "$DOTTY_REGISTRY" 2>/dev/null; then
        # Update existing entry (portable sed)
        local tmp="$DOTTY_REGISTRY.tmp"
        grep -v "^${name}=" "$DOTTY_REGISTRY" > "$tmp" || true
        echo "${name}=${path}" >> "$tmp"
        mv "$tmp" "$DOTTY_REGISTRY"
    else
        echo "${name}=${path}" >> "$DOTTY_REGISTRY"
    fi
}

registry_remove() {
    local name="$1"
    local tmp="$DOTTY_REGISTRY.tmp"
    grep -v "^${name}=" "$DOTTY_REGISTRY" > "$tmp" 2>/dev/null || true
    mv "$tmp" "$DOTTY_REGISTRY"
}

registry_names() {
    cut -d= -f1 "$DOTTY_REGISTRY" 2>/dev/null
}

# Operation lock

_current_pid() {
    printf '%s\n' "${BASHPID:-$$}"
}

_dotty_operation_lock_dir() {
    printf '%s\n' "$DOTTY_DIR/operation.lock"
}

_read_lock_file() {
    local path="$1"
    [[ -f "$path" ]] || return 1
    sed -n '1p' "$path" 2>/dev/null || true
}

_operation_lock_description() {
    local lock_dir="$1"
    local command_name=""
    local lock_pid=""
    local started_at=""
    local host=""
    local description=""

    command_name="$(_read_lock_file "$lock_dir/command" || true)"
    lock_pid="$(_read_lock_file "$lock_dir/pid" || true)"
    started_at="$(_read_lock_file "$lock_dir/started-at" || true)"
    host="$(_read_lock_file "$lock_dir/host" || true)"

    if [[ -n "$command_name" ]]; then
        description+="dotty $command_name"
    else
        description+="dotty operation"
    fi

    [[ -n "$lock_pid" ]] && description+=" pid $lock_pid"
    [[ -n "$host" ]] && description+=" on $host"
    [[ -n "$started_at" ]] && description+=" since $started_at"

    printf '%s\n' "$description"
}

_operation_lock_active() {
    local lock_dir="$1"
    local lock_pid=""

    [[ -d "$lock_dir" ]] || return 1

    lock_pid="$(_read_lock_file "$lock_dir/pid" || true)"
    if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
        return 0
    fi

    warning "Removing stale dotty operation lock at $lock_dir"
    rm -rf "$lock_dir"
    return 1
}

_acquire_operation_lock() {
    local command_name="$1"
    local lock_dir=""
    local next_notice=0
    local now=0
    local owner_pid="${BASHPID:-$$}"

    mkdir -p "$DOTTY_DIR"
    lock_dir="$(_dotty_operation_lock_dir)"

    while ! mkdir "$lock_dir" 2>/dev/null; do
        if ! _operation_lock_active "$lock_dir"; then
            continue
        fi

        now="$(date +%s)"
        if [[ "$now" -ge "$next_notice" ]]; then
            warning "Waiting for $(_operation_lock_description "$lock_dir")"
            next_notice=$((now + 10))
        fi

        sleep 1
    done

    _DOTTY_OPERATION_LOCK_DIR="$lock_dir"
    _DOTTY_OPERATION_LOCK_PID="$owner_pid"
    printf '%s\n' "$owner_pid" > "$lock_dir/pid"
    printf '%s\n' "$command_name" > "$lock_dir/command"
    date -u '+%Y-%m-%dT%H:%M:%SZ' > "$lock_dir/started-at"
    hostname > "$lock_dir/host" 2>/dev/null || true
}

_release_operation_lock() {
    local lock_dir="${_DOTTY_OPERATION_LOCK_DIR:-}"
    local lock_pid=""

    [[ -n "$lock_dir" && -d "$lock_dir" ]] || return 0

    lock_pid="$(_read_lock_file "$lock_dir/pid" || true)"
    if [[ -z "$lock_pid" || "$lock_pid" == "$_DOTTY_OPERATION_LOCK_PID" ]]; then
        rm -rf "$lock_dir"
    fi

    _DOTTY_OPERATION_LOCK_DIR=""
    _DOTTY_OPERATION_LOCK_PID=""
}

_run_with_operation_lock() {
    local command_name="$1"
    shift

    local status=0

    _acquire_operation_lock "$command_name"
    trap _release_operation_lock EXIT

    "$@" || status=$?

    _release_operation_lock
    trap - EXIT

    return "$status"
}

# Config reading

# Find the config file for a repo. Returns 1 if not found.
_find_config() {
    local repo_dir="$1"
    if [[ -f "$repo_dir/.dotty/config" ]]; then
        echo "$repo_dir/.dotty/config"
    else
        return 1
    fi
}

# Find the hook script for a repo. Returns 1 if not found.
_find_hook() {
    local repo_dir="$1"
    if [[ -f "$repo_dir/.dotty/run.sh" ]]; then
        echo "$repo_dir/.dotty/run.sh"
    else
        return 1
    fi
}

# Find the commands directory for a repo. Returns 1 if not found.
_find_commands_dir() {
    local repo_dir="$1"
    if [[ -d "$repo_dir/.dotty/commands" ]]; then
        echo "$repo_dir/.dotty/commands"
    else
        return 1
    fi
}

# Find the cleanups directory for a repo. Returns 1 if not found.
_find_cleanups_dir() {
    local repo_dir="$1"
    if [[ -d "$repo_dir/.dotty/cleanups" ]]; then
        echo "$repo_dir/.dotty/cleanups"
    else
        return 1
    fi
}

# Returns true if the repo has a config file.
_has_config() {
    local repo_dir="$1"
    [[ -f "$repo_dir/.dotty/config" ]]
}

_reset_config_state() {
    DOTTY_NAME=""
    DOTTY_EXTENDS=()
    DOTTY_ENVIRONMENTS=()
    DOTTY_ENV_DETECT=""
    DOTTY_LINK_IGNORE=()
}

_CONFIG_LOAD_ERROR=""
_CLEANUP_CONFIG_LOAD_ERROR=""

_load_config_file() {
    local conf="$1"

    _CONFIG_LOAD_ERROR=""
    _reset_config_state

    # shellcheck disable=SC1090
    if ! source "$conf"; then
        _CONFIG_LOAD_ERROR="Failed to load $conf"
        return 1
    fi

    if [[ -z "$DOTTY_NAME" ]]; then
        _CONFIG_LOAD_ERROR="DOTTY_NAME is required in $conf"
        return 1
    fi
}

_reset_cleanup_config_state() {
    local var
    while IFS= read -r var; do
        case "$var" in
            DOTTY_CLEANUP_ENVIRONMENTS|DOTTY_CLEANUP_MACHINES|DOTTY_CLEANUP_DESCRIPTION)
                ;;
            *)
                unset "$var"
                ;;
        esac
    done < <(compgen -A variable DOTTY_CLEANUP_ || true)

    DOTTY_CLEANUP_ENVIRONMENTS=()
    DOTTY_CLEANUP_MACHINES=()
    DOTTY_CLEANUP_DESCRIPTION=""
}

_load_cleanup_config_file() {
    local conf="$1"

    _CLEANUP_CONFIG_LOAD_ERROR=""
    _reset_cleanup_config_state

    # shellcheck disable=SC1090
    if ! source "$conf"; then
        _CLEANUP_CONFIG_LOAD_ERROR="Failed to load $conf"
        return 1
    fi

    local var
    while IFS= read -r var; do
        case "$var" in
            DOTTY_CLEANUP_ENVIRONMENTS|DOTTY_CLEANUP_MACHINES|DOTTY_CLEANUP_DESCRIPTION)
                ;;
            *)
                _CLEANUP_CONFIG_LOAD_ERROR="Unsupported cleanup config variable: $var"
                return 1
                ;;
        esac
    done < <(compgen -A variable DOTTY_CLEANUP_ || true)
}

# Sets: DOTTY_NAME, DOTTY_EXTENDS, DOTTY_ENVIRONMENTS, DOTTY_ENV_DETECT
read_config() {
    local repo_dir="$1"
    local conf
    conf="$(_find_config "$repo_dir")" || die "No .dotty/config found in $repo_dir"

    _load_config_file "$conf" || die "${_CONFIG_LOAD_ERROR:-Invalid config: $conf}"
}

_is_declared_env() {
    local name="$1"
    local env
    for env in ${DOTTY_ENVIRONMENTS[@]+"${DOTTY_ENVIRONMENTS[@]}"}; do
        [[ "$env" == "$name" ]] && return 0
    done
    return 1
}

# Chain resolution

CHAIN_NAMES=()
CHAIN_PATHS=()
_RESOLVING=()

resolve_chain() {
    local repo_dir
    repo_dir="$(cd "$1" && pwd)"

    read_config "$repo_dir"
    local name="$DOTTY_NAME"

    # Skip if already resolved (diamond dependency deduplication)
    for existing in ${CHAIN_NAMES[@]+"${CHAIN_NAMES[@]}"}; do
        [[ "$existing" == "$name" ]] && return 0
    done

    # Cycle detection (only tracks the current recursion stack)
    for r in ${_RESOLVING[@]+"${_RESOLVING[@]}"}; do
        [[ "$r" == "$name" ]] && die "Dependency cycle detected: $name"
    done
    _RESOLVING+=("$name")

    # Resolve parents first (so base repos come first in chain)
    local parent_url
    for parent_url in ${DOTTY_EXTENDS[@]+"${DOTTY_EXTENDS[@]}"}; do
        local parent_dir
        parent_dir="$(ensure_repo "$parent_url")"
        resolve_chain "$parent_dir"
    done

    # Pop self from the resolving stack
    unset '_RESOLVING[${#_RESOLVING[@]}-1]'

    CHAIN_NAMES+=("$name")
    CHAIN_PATHS+=("$repo_dir")
}

resolve_chain_from_leaf() {
    registry_init

    local -a all_paths=()
    while IFS='=' read -r name rpath; do
        [[ -n "$name" && -d "$rpath" ]] && all_paths+=("$rpath")
    done < "$DOTTY_REGISTRY"

    [[ ${#all_paths[@]} -gt 0 ]] || die "No repos registered. Run 'dotty install' first."

    local best_len=0
    local -a best_names=() best_paths=()
    for rpath in "${all_paths[@]}"; do
        _has_config "$rpath" || continue
        CHAIN_NAMES=()
        CHAIN_PATHS=()
        _RESOLVING=()
        resolve_chain "$rpath" 2>/dev/null || true
        if [[ ${#CHAIN_NAMES[@]} -gt $best_len ]]; then
            best_len=${#CHAIN_NAMES[@]}
            best_names=()
            best_paths=()
            local chain_name
            local chain_path
            for chain_name in ${CHAIN_NAMES[@]+"${CHAIN_NAMES[@]}"}; do
                best_names+=("$chain_name")
            done
            for chain_path in ${CHAIN_PATHS[@]+"${CHAIN_PATHS[@]}"}; do
                best_paths+=("$chain_path")
            done
        fi
    done
    CHAIN_NAMES=()
    CHAIN_PATHS=()
    local best_name
    local best_path
    for best_name in ${best_names[@]+"${best_names[@]}"}; do
        CHAIN_NAMES+=("$best_name")
    done
    for best_path in ${best_paths[@]+"${best_paths[@]}"}; do
        CHAIN_PATHS+=("$best_path")
    done
}

ensure_repo() {
    local source="$1"
    local target_dir="${2:-}"

    if [[ -d "$source" ]]; then
        (cd "$source" && pwd)
        return 0
    fi

    # Check registry — the repo name often matches the URL basename
    local url_basename
    url_basename="$(basename "$source" .git)"
    local registered_path
    registered_path="$(registry_get "$url_basename")" || true
    if [[ -n "$registered_path" && -d "$registered_path" ]] && _has_config "$registered_path"; then
        echo "$registered_path"
        return 0
    fi

    # Check if already cloned in DOTTY_REPOS_DIR
    for dir in "$DOTTY_REPOS_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local _conf
        _conf="$(_find_config "$dir")" || true
        if [[ -n "$_conf" ]]; then
            local found_name
            found_name="$(DOTTY_NAME=""; DOTTY_EXTENDS=(); DOTTY_ENVIRONMENTS=(); DOTTY_ENV_DETECT=""; source "$_conf"; echo "$DOTTY_NAME")"
            if [[ -n "$found_name" ]]; then
                local found_path
                found_path="$(registry_get "$found_name")" || true
                if [[ -n "$found_path" && -d "$found_path" ]]; then
                    echo "$found_path"
                    return 0
                fi
            fi
        fi
    done

    # If a target_dir was specified, check it before falling back to DOTTY_REPOS_DIR
    if [[ -n "$target_dir" && -d "$target_dir" ]]; then
        if _has_config "$target_dir"; then
            echo "$target_dir"
            return 0
        else
            die "$target_dir already exists but is not a dotty repo"
        fi
    fi

    local clone_name
    clone_name="$(basename "$source" .git)"
    local clone_dir="${target_dir:-$DOTTY_REPOS_DIR/$clone_name}"

    if [[ -d "$clone_dir" ]]; then
        echo "$clone_dir"
        return 0
    fi

    info "Cloning $source..." >&2
    git clone "$source" "$clone_dir" >&2 || die "Failed to clone $source"

    # Read its name and register
    local _clone_conf
    _clone_conf="$(_find_config "$clone_dir")" || true
    if [[ -n "$_clone_conf" ]]; then
        local cloned_name
        cloned_name="$(DOTTY_NAME=""; DOTTY_EXTENDS=(); DOTTY_ENVIRONMENTS=(); DOTTY_ENV_DETECT=""; source "$_clone_conf"; echo "$DOTTY_NAME")"
        if [[ -n "$cloned_name" ]]; then
            registry_set "$cloned_name" "$clone_dir"
        fi
    fi

    echo "$clone_dir"
}

# Environment detection

detect_environment() {
    local i
    for (( i=${#CHAIN_PATHS[@]}-1; i>=0; i-- )); do
        local dir="${CHAIN_PATHS[$i]}"
        local _econf
        _econf="$(_find_config "$dir")" || continue
        local env_detect
        env_detect="$(DOTTY_ENV_DETECT=""; DOTTY_EXTENDS=(); DOTTY_ENVIRONMENTS=(); source "$_econf"; echo "$DOTTY_ENV_DETECT")"
        if [[ -n "$env_detect" ]]; then
            local detected
            detected="$(eval "$env_detect")"
            if [[ -n "$detected" ]]; then
                echo "$detected"
                return 0
            fi
        fi
    done
}

# Core operations

pull_if_clean() {
    local dir="$1"
    if [[ ! -d "$dir/.git" ]]; then
        return 0
    fi

    local stashed=false
    if ! (cd "$dir" && git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null); then
        info "Stashing changes in $(basename "$dir")..."
        (cd "$dir" && git stash --quiet 2>/dev/null) && stashed=true
    fi

    local before after
    before="$(cd "$dir" && git rev-parse HEAD 2>/dev/null)" || true

    info "Pulling $(basename "$dir")..."
    if ! (cd "$dir" && git pull --rebase 2>/dev/null); then
        warning "Failed to pull $(basename "$dir")"
        (cd "$dir" && git rebase --abort 2>/dev/null) || true
    fi

    after="$(cd "$dir" && git rev-parse HEAD 2>/dev/null)" || true
    if [[ -n "$before" && -n "$after" && "$before" != "$after" ]]; then
        _DOTTY_CHANGES_MADE=true
    fi

    if [[ "$stashed" == "true" ]]; then
        (cd "$dir" && git stash pop --quiet 2>/dev/null) || warning "Failed to restore stashed changes in $(basename "$dir")"
    fi
}

_normalize_update_jobs() {
    local raw="${DOTTY_UPDATE_JOBS:-1}"
    if [[ -z "$raw" ]]; then
        printf '1\n'
        return 0
    fi

    if [[ "$raw" == *[!0-9]* ]]; then
        warning "Invalid DOTTY_UPDATE_JOBS '$raw'; using 1"
        printf '1\n'
        return 0
    fi

    local jobs
    jobs=$((10#$raw))
    if [[ "$jobs" -lt 1 ]]; then
        warning "Invalid DOTTY_UPDATE_JOBS '$raw'; using 1"
        printf '1\n'
        return 0
    fi

    printf '%s\n' "$jobs"
}

_wait_for_update_pull_jobs() {
    local pid
    for pid in "$@"; do
        wait "$pid" || true
    done
}

_run_update_pull_job() {
    local dir="$1"
    local log_path="$2"
    local result_path="$3"

    (
        _DOTTY_CHANGES_MADE=false
        pull_if_clean "$dir" || true
        if [[ "$_DOTTY_CHANGES_MADE" == "true" ]]; then
            printf 'changed\n' > "$result_path"
        else
            printf 'unchanged\n' > "$result_path"
        fi
    ) > "$log_path" 2>&1
}

_run_parallel_update_pulls() {
    local jobs="$1"
    local tmp_dir
    tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/dotty-update-pulls.XXXXXX")" || die "Failed to create temp directory for update pulls"

    local pids=()
    local active=0
    local i
    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        _run_update_pull_job "${CHAIN_PATHS[$i]}" "$tmp_dir/$i.log" "$tmp_dir/$i.result" &
        pids+=("$!")
        active=$((active + 1))

        if [[ "$active" -ge "$jobs" ]]; then
            _wait_for_update_pull_jobs "${pids[@]}"
            pids=()
            active=0
        fi
    done

    if [[ "$active" -gt 0 ]]; then
        _wait_for_update_pull_jobs "${pids[@]}"
    fi

    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        if [[ -s "$tmp_dir/$i.log" ]]; then
            cat "$tmp_dir/$i.log"
        fi

        if [[ -f "$tmp_dir/$i.result" && "$(cat "$tmp_dir/$i.result")" == "changed" ]]; then
            _DOTTY_CHANGES_MADE=true
        fi
    done

    rm -rf "$tmp_dir"
}

# Pull the dotty repo itself before processing the chain. The script is
# wrapped in { ... } braces so bash reads it fully into memory before
# executing, making mid-run file changes safe. The updated script takes
# effect on the next invocation.
self_update() {
    # Non-git installs (e.g. manual copy) can't self-update.
    if [[ ! -d "$DOTTY_DIR/.git" ]]; then
        return 0
    fi

    if [[ "${DOTTY_DRY_RUN:-false}" == "true" ]]; then
        info "[dry-run] Would pull dotty repo ($DOTTY_DIR)"
        return 0
    fi

    pull_if_clean "$DOTTY_DIR"
}

_write_reload_marker() {
    if [[ "$_DOTTY_CHANGES_MADE" == "true" && "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
        touch "$DOTTY_DIR/.needs-reload"
    fi
}

_current_machine_id() {
    if [[ -n "${DOTTY_MACHINE_ID:-}" ]]; then
        printf '%s\n' "$DOTTY_MACHINE_ID"
        return 0
    fi

    local machine_id_file="$DOTTY_DIR/machine-id"
    if [[ -f "$machine_id_file" ]]; then
        local machine_id
        machine_id="$(sed -n '1p' "$machine_id_file")"
        if [[ -n "$machine_id" ]]; then
            printf '%s\n' "$machine_id"
            return 0
        fi
    fi

    return 1
}

_cleanup_state_dir() {
    local repo_name="$1"
    local cleanup_id="$2"
    printf '%s\n' "$DOTTY_CLEANUPS_DIR/$repo_name/$cleanup_id"
}

_cleanup_status() {
    local repo_name="$1"
    local cleanup_id="$2"
    local state_dir
    state_dir="$(_cleanup_state_dir "$repo_name" "$cleanup_id")"

    if [[ -f "$state_dir/done" ]]; then
        printf 'done\n'
    elif [[ -f "$state_dir/failed" ]]; then
        printf 'failed\n'
    else
        printf 'pending\n'
    fi
}

_cleanup_script_path() {
    local cleanup_path="$1"

    if [[ -f "$cleanup_path" ]]; then
        printf '%s\n' "$cleanup_path"
        return 0
    fi

    if [[ -d "$cleanup_path" && -f "$cleanup_path/run.sh" ]]; then
        printf '%s\n' "$cleanup_path/run.sh"
        return 0
    fi

    return 1
}

_cleanup_config_path() {
    local cleanup_path="$1"

    if [[ -d "$cleanup_path" && -f "$cleanup_path/config" ]]; then
        printf '%s\n' "$cleanup_path/config"
        return 0
    fi

    return 1
}

_cleanup_metadata_load() {
    local cleanup_path="$1"
    local config_path

    _reset_cleanup_config_state
    config_path="$(_cleanup_config_path "$cleanup_path")" || return 0
    _load_cleanup_config_file "$config_path"
}

_cleanup_applies_to_env() {
    local env="$1"

    [[ ${#DOTTY_CLEANUP_ENVIRONMENTS[@]} -eq 0 ]] && return 0
    [[ -n "$env" ]] || return 1

    local target_env
    for target_env in ${DOTTY_CLEANUP_ENVIRONMENTS[@]+"${DOTTY_CLEANUP_ENVIRONMENTS[@]}"}; do
        [[ "$target_env" == "$env" ]] && return 0
    done

    return 1
}

_cleanup_applies_to_machine() {
    local machine_id="$1"

    [[ ${#DOTTY_CLEANUP_MACHINES[@]} -eq 0 ]] && return 0
    [[ -n "$machine_id" ]] || return 1

    local target_machine
    for target_machine in ${DOTTY_CLEANUP_MACHINES[@]+"${DOTTY_CLEANUP_MACHINES[@]}"}; do
        [[ "$target_machine" == "$machine_id" ]] && return 0
    done

    return 1
}

_cleanup_not_applicable_reason() {
    local env="$1"
    local machine_id="$2"

    if ! _cleanup_applies_to_env "$env"; then
        if [[ -z "$env" ]]; then
            printf 'environment unavailable\n'
        else
            printf 'environment %s\n' "$env"
        fi
        return 0
    fi

    if ! _cleanup_applies_to_machine "$machine_id"; then
        if [[ -z "$machine_id" ]]; then
            printf 'machine id unavailable\n'
        else
            printf 'machine %s\n' "$machine_id"
        fi
        return 0
    fi

    printf '\n'
}

_cleanup_record_success() {
    local repo_name="$1"
    local cleanup_id="$2"
    local script_path="$3"
    local state_dir
    state_dir="$(_cleanup_state_dir "$repo_name" "$cleanup_id")"

    mkdir -p "$state_dir"
    printf '%s\n' "$script_path" > "$state_dir/source"
    date -u '+%Y-%m-%dT%H:%M:%SZ' > "$state_dir/completed-at"
    : > "$state_dir/done"
    rm -f "$state_dir/failed" "$state_dir/failed-at" "$state_dir/exit-code"
}

_cleanup_record_failure() {
    local repo_name="$1"
    local cleanup_id="$2"
    local script_path="$3"
    local exit_code="$4"
    local state_dir
    state_dir="$(_cleanup_state_dir "$repo_name" "$cleanup_id")"

    mkdir -p "$state_dir"
    printf '%s\n' "$script_path" > "$state_dir/source"
    printf '%s\n' "$exit_code" > "$state_dir/exit-code"
    date -u '+%Y-%m-%dT%H:%M:%SZ' > "$state_dir/failed-at"
    : > "$state_dir/failed"
}

run_pending_cleanups() {
    local repo_dir="$1"
    local repo_name="$2"
    local env="$3"
    local command="$4"

    [[ "$command" == "install" || "$command" == "update" ]] || return 0

    local cleanups_dir
    cleanups_dir="$(_find_cleanups_dir "$repo_dir")" || return 0

    local machine_id=""
    machine_id="$(_current_machine_id 2>/dev/null)" || true

    local cleanup_path
    for cleanup_path in "$cleanups_dir"/*; do
        [[ -e "$cleanup_path" || -L "$cleanup_path" ]] || continue

        local cleanup_id
        cleanup_id="$(basename "$cleanup_path")"
        [[ "$cleanup_id" == .* ]] && continue

        if [[ -L "$cleanup_path" && ! -e "$cleanup_path" ]]; then
            warning "cleanup '$cleanup_id' is a broken symlink in $repo_name"
            _CLEANUP_ERRORS+=("$repo_name/$cleanup_id")
            continue
        fi

        local script_path
        script_path="$(_cleanup_script_path "$cleanup_path")" || {
            warning "cleanup '$cleanup_id' is malformed in $repo_name"
            _CLEANUP_ERRORS+=("$repo_name/$cleanup_id")
            continue
        }

        if [[ ! -x "$script_path" ]]; then
            warning "cleanup '$cleanup_id' exists but is not executable in $repo_name"
            _CLEANUP_ERRORS+=("$repo_name/$cleanup_id")
            continue
        fi

        if ! _cleanup_metadata_load "$cleanup_path"; then
            warning "cleanup '$cleanup_id' config is invalid in $repo_name: ${_CLEANUP_CONFIG_LOAD_ERROR:-unknown error}"
            _CLEANUP_ERRORS+=("$repo_name/$cleanup_id")
            continue
        fi

        if ! _cleanup_applies_to_env "$env" || ! _cleanup_applies_to_machine "$machine_id"; then
            verbose_info "Skipping cleanup '$cleanup_id' in $repo_name ($(_cleanup_not_applicable_reason "$env" "$machine_id"))"
            continue
        fi

        local status
        status="$(_cleanup_status "$repo_name" "$cleanup_id")"
        if [[ "$status" == "done" ]]; then
            verbose_info "Skipping completed cleanup '$cleanup_id' in $repo_name"
            continue
        fi

        if [[ "${DOTTY_DRY_RUN:-false}" == "true" ]]; then
            info "[dry-run] Would run cleanup '$cleanup_id' in $repo_name"
            continue
        fi

        local state_dir
        state_dir="$(_cleanup_state_dir "$repo_name" "$cleanup_id")"
        mkdir -p "$state_dir"
        info "Running cleanup $cleanup_id"
        if (
            export DOTTY_REPO_DIR="$repo_dir"
            export DOTTY_ENV="${env:-}"
            export DOTTY_COMMAND="${command:-}"
            export DOTTY_VERBOSE
            export DOTTY_DRY_RUN
            export DOTTY_LIB
            export DOTTY_CLEANUP_ID="$cleanup_id"
            export DOTTY_CLEANUP_STATE_DIR="$state_dir"
            if [[ -n "$machine_id" ]]; then
                export DOTTY_MACHINE_ID="$machine_id"
            fi
            DOTTY_LIB="$(cd "$(dirname "$0")" && pwd)/lib/utils.sh"
            cd "$repo_dir"
            "$script_path"
        ); then
            _cleanup_record_success "$repo_name" "$cleanup_id" "$script_path"
        else
            local exit_code=$?
            _cleanup_record_failure "$repo_name" "$cleanup_id" "$script_path" "$exit_code"
            warning "cleanup '$cleanup_id' failed in $repo_name (exit $exit_code)"
            _CLEANUP_ERRORS+=("$repo_name/$cleanup_id")
        fi
    done
}

process_repo() {
    local repo_dir="$1"
    local env="${2:-}"
    local command="${3:-}"

    read_config "$repo_dir"
    local name="$DOTTY_NAME"

    title "Processing $name"

    local do_env_overlay=false
    if [[ -n "$env" && ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]]; then
        if _is_declared_env "$env"; then
            [[ -d "$repo_dir/$env/home" ]] && do_env_overlay=true
        else
            warning "Detected environment '$env' not in DOTTY_ENVIRONMENTS for $name"
        fi
    fi

    # Clean up orphan symlinks (files removed from repo since last link)
    if [[ -d "$repo_dir/home" ]]; then
        cleanup_orphans "$repo_dir/home" "$HOME"
    fi
    if [[ "$do_env_overlay" == "true" ]]; then
        cleanup_orphans "$repo_dir/$env/home" "$HOME"
    fi

    # Symlink home/ → $HOME
    if [[ -d "$repo_dir/home" ]]; then
        info "Linking home/"
        create_symlinks_from_dir "$repo_dir/home" "$HOME"
    fi

    # Environment overlay: $env/home/ → $HOME
    if [[ "$do_env_overlay" == "true" ]]; then
        info "Linking $env/home/ overlay"
        create_symlinks_from_dir "$repo_dir/$env/home" "$HOME"
    fi

    # Run one-shot cleanup tasks after links are refreshed and before hooks.
    run_pending_cleanups "$repo_dir" "$name" "$env" "$command"

    # Run hook (non-fatal so later repos still process).
    # Hooks are skipped during "link" (symlink-only mode) and dry-run.
    if [[ "$command" != "link" && "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
        local hook_script
        hook_script="$(_find_hook "$repo_dir")" || true
        if [[ -n "$hook_script" && -x "$hook_script" ]]; then
            local hook_name
            hook_name="$(basename "$hook_script")"
            info "Running $hook_name"
            (
                export DOTTY_REPO_DIR="$repo_dir"
                export DOTTY_ENV="${env:-}"
                export DOTTY_COMMAND="${command:-}"
                export DOTTY_VERBOSE
                export DOTTY_DRY_RUN
                export DOTTY_LIB
                DOTTY_LIB="$(cd "$(dirname "$0")" && pwd)/lib/utils.sh"
                cd "$repo_dir"
                "$hook_script"
            ) || { warning "$hook_name failed in $name (exit $?)"; _HOOK_ERRORS+=("$name"); }
        elif [[ -n "$hook_script" ]]; then
            local hook_name
            hook_name="$(basename "$hook_script")"
            warning "$hook_name exists but is not executable in $name"
        fi
    fi
}

run_chain() {
    local pull="${1:-true}"
    local command="${2:-}"
    local env
    env="$(detect_environment)"

    if [[ -n "$env" ]]; then
        info "Detected environment: $env"
        export DOTTY_ENV="$env"
    fi

    _HOOK_ERRORS=()
    _CLEANUP_ERRORS=()
    _LINK_FAIL_COUNT=0

    # Register all repos first so the registry is complete even if a hook fails.
    local i
    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        registry_set "${CHAIN_NAMES[$i]}" "${CHAIN_PATHS[$i]}"
    done

    local update_jobs=1
    if [[ "$pull" == "true" && "$command" == "update" && "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
        update_jobs="$(_normalize_update_jobs)"
    fi

    if [[ "$pull" == "true" && "$command" == "update" && "${DOTTY_DRY_RUN:-false}" != "true" && "$update_jobs" -gt 1 ]]; then
        _run_parallel_update_pulls "$update_jobs"

        for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
            local dir="${CHAIN_PATHS[$i]}"
            process_repo "$dir" "$env" "$command"
        done
    else
        for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
            local dir="${CHAIN_PATHS[$i]}"

            if [[ "$pull" == "true" && "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
                pull_if_clean "$dir"
            fi

            process_repo "$dir" "$env" "$command"
        done
    fi

    # Print error summary if anything went wrong
    _CHAIN_HAD_ERRORS=false
    if [[ ${#_HOOK_ERRORS[@]} -gt 0 ]]; then
        _CHAIN_HAD_ERRORS=true
        warning "Hook failures: ${_HOOK_ERRORS[*]}"
    fi
    if [[ ${#_CLEANUP_ERRORS[@]} -gt 0 ]]; then
        _CHAIN_HAD_ERRORS=true
        warning "Cleanup failures: ${_CLEANUP_ERRORS[*]}"
    fi
    if [[ $_LINK_FAIL_COUNT -gt 0 ]]; then
        _CHAIN_HAD_ERRORS=true
        warning "$_LINK_FAIL_COUNT symlink(s) failed to create"
    fi
}

doctor_success() {
    success "$1"
}

doctor_warn() {
    _DOCTOR_WARN_COUNT=$((_DOCTOR_WARN_COUNT + 1))
    warning "$1"
}

doctor_fail() {
    _DOCTOR_FAIL_COUNT=$((_DOCTOR_FAIL_COUNT + 1))
    echo -e "${COLOR_RED}✖ $1${COLOR_NONE}" >&2
}

_DOCTOR_ERROR=""
_DOCTOR_CHAIN_NAMES=()
_DOCTOR_CHAIN_PATHS=()
_DOCTOR_RESOLVING=()

_doctor_read_config() {
    local repo_dir="$1"
    local conf
    conf="$(_find_config "$repo_dir")" || {
        _DOCTOR_ERROR="No .dotty/config found in $repo_dir"
        return 1
    }

    if ! _load_config_file "$conf"; then
        _DOCTOR_ERROR="${_CONFIG_LOAD_ERROR:-Invalid config: $conf}"
        return 1
    fi
}

_doctor_lookup_source() {
    local source="$1"

    if [[ -d "$source" ]]; then
        (cd "$source" && pwd)
        return 0
    fi

    local source_name
    source_name="$(basename "$source" .git)"

    local registered_path
    registered_path="$(registry_get "$source_name")" || true
    if [[ -n "$registered_path" && -d "$registered_path" ]]; then
        (cd "$registered_path" && pwd)
        return 0
    fi

    local clone_dir="$DOTTY_REPOS_DIR/$source_name"
    if [[ -d "$clone_dir" ]]; then
        (cd "$clone_dir" && pwd)
        return 0
    fi

    return 1
}

_doctor_resolve_chain_no_clone() {
    local repo_dir
    repo_dir="$(cd "$1" && pwd)"

    if ! _doctor_read_config "$repo_dir"; then
        return 1
    fi

    local name="$DOTTY_NAME"
    local existing
    for existing in ${_DOCTOR_CHAIN_NAMES[@]+"${_DOCTOR_CHAIN_NAMES[@]}"}; do
        [[ "$existing" == "$name" ]] && return 0
    done

    local pending
    for pending in ${_DOCTOR_RESOLVING[@]+"${_DOCTOR_RESOLVING[@]}"}; do
        if [[ "$pending" == "$name" ]]; then
            _DOCTOR_ERROR="Dependency cycle detected at $name"
            return 1
        fi
    done
    _DOCTOR_RESOLVING+=("$name")

    local parent_source
    for parent_source in ${DOTTY_EXTENDS[@]+"${DOTTY_EXTENDS[@]}"}; do
        local parent_dir
        parent_dir="$(_doctor_lookup_source "$parent_source")" || {
            _DOCTOR_ERROR="$name depends on $parent_source, but it is not installed or registered"
            return 1
        }
        _doctor_resolve_chain_no_clone "$parent_dir" || return 1
    done

    unset '_DOCTOR_RESOLVING[${#_DOCTOR_RESOLVING[@]}-1]'

    _DOCTOR_CHAIN_NAMES+=("$name")
    _DOCTOR_CHAIN_PATHS+=("$repo_dir")
}

_doctor_resolve_from_leaf_no_clone() {
    local best_len=0
    local found_valid=false
    local -a best_names=() best_paths=()

    while IFS='=' read -r _name rpath; do
        [[ -n "$rpath" && -d "$rpath" ]] || continue

        _DOCTOR_CHAIN_NAMES=()
        _DOCTOR_CHAIN_PATHS=()
        _DOCTOR_RESOLVING=()
        _DOCTOR_ERROR=""

        if ! _doctor_resolve_chain_no_clone "$rpath"; then
            continue
        fi

        found_valid=true
        if [[ ${#_DOCTOR_CHAIN_NAMES[@]} -gt $best_len ]]; then
            best_len=${#_DOCTOR_CHAIN_NAMES[@]}
            best_names=()
            best_paths=()
            local doctor_name
            local doctor_path
            for doctor_name in ${_DOCTOR_CHAIN_NAMES[@]+"${_DOCTOR_CHAIN_NAMES[@]}"}; do
                best_names+=("$doctor_name")
            done
            for doctor_path in ${_DOCTOR_CHAIN_PATHS[@]+"${_DOCTOR_CHAIN_PATHS[@]}"}; do
                best_paths+=("$doctor_path")
            done
        fi
    done < "$DOTTY_REGISTRY"

    _DOCTOR_CHAIN_NAMES=()
    _DOCTOR_CHAIN_PATHS=()
    local best_doctor_name
    local best_doctor_path
    for best_doctor_name in ${best_names[@]+"${best_names[@]}"}; do
        _DOCTOR_CHAIN_NAMES+=("$best_doctor_name")
    done
    for best_doctor_path in ${best_paths[@]+"${best_paths[@]}"}; do
        _DOCTOR_CHAIN_PATHS+=("$best_doctor_path")
    done

    [[ "$found_valid" == "true" ]]
}

_doctor_check_hook() {
    local repo_name="$1"
    local repo_dir="$2"
    local hook_path="$repo_dir/.dotty/run.sh"

    if [[ -L "$hook_path" && ! -e "$hook_path" ]]; then
        doctor_fail "$repo_name: .dotty/run.sh is a broken symlink"
        return 0
    fi

    if [[ ! -e "$hook_path" ]]; then
        doctor_success "$repo_name: no hook script"
        return 0
    fi

    if [[ ! -f "$hook_path" ]]; then
        doctor_fail "$repo_name: .dotty/run.sh exists but is not a file"
        return 0
    fi

    if [[ ! -x "$hook_path" ]]; then
        doctor_fail "$repo_name: .dotty/run.sh exists but is not executable"
        return 0
    fi

    doctor_success "$repo_name: hook is executable"
}

_doctor_check_commands() {
    local repo_name="$1"
    local repo_dir="$2"
    local commands_dir="$repo_dir/.dotty/commands"
    local found_commands=false

    if [[ -L "$commands_dir" && ! -e "$commands_dir" ]]; then
        doctor_fail "$repo_name: .dotty/commands is a broken symlink"
        return 0
    fi

    if [[ ! -e "$commands_dir" ]]; then
        doctor_success "$repo_name: no repo commands"
        return 0
    fi

    if [[ ! -d "$commands_dir" ]]; then
        doctor_fail "$repo_name: .dotty/commands exists but is not a directory"
        return 0
    fi

    local item
    for item in "$commands_dir"/* "$commands_dir"/.*; do
        [[ -e "$item" || -L "$item" ]] || continue

        local command_name
        command_name="$(basename "$item")"
        [[ "$command_name" == "." || "$command_name" == ".." || "$command_name" == .* ]] && continue

        found_commands=true

        if [[ -L "$item" && ! -e "$item" ]]; then
            doctor_fail "$repo_name: command '$command_name' is a broken symlink"
            continue
        fi

        if [[ ! -f "$item" ]]; then
            doctor_fail "$repo_name: command '$command_name' is not a file"
            continue
        fi

        if [[ ! -x "$item" ]]; then
            doctor_fail "$repo_name: command '$command_name' exists but is not executable"
            continue
        fi

        doctor_success "$repo_name: command '$command_name' is executable"
    done

    if [[ "$found_commands" == "false" ]]; then
        doctor_success "$repo_name: no repo commands"
    fi
}

_doctor_check_cleanups() {
    local repo_name="$1"
    local repo_dir="$2"
    local cleanups_dir="$repo_dir/.dotty/cleanups"
    local found_cleanups=false

    if [[ -L "$cleanups_dir" && ! -e "$cleanups_dir" ]]; then
        doctor_fail "$repo_name: .dotty/cleanups is a broken symlink"
        return 0
    fi

    if [[ ! -e "$cleanups_dir" ]]; then
        doctor_success "$repo_name: no cleanup tasks"
        return 0
    fi

    if [[ ! -d "$cleanups_dir" ]]; then
        doctor_fail "$repo_name: .dotty/cleanups exists but is not a directory"
        return 0
    fi

    local item
    for item in "$cleanups_dir"/* "$cleanups_dir"/.*; do
        [[ -e "$item" || -L "$item" ]] || continue

        local cleanup_id
        cleanup_id="$(basename "$item")"
        [[ "$cleanup_id" == "." || "$cleanup_id" == ".." || "$cleanup_id" == .* ]] && continue

        found_cleanups=true

        if [[ -L "$item" && ! -e "$item" ]]; then
            doctor_fail "$repo_name: cleanup '$cleanup_id' is a broken symlink"
            continue
        fi

        local script_path=""
        if [[ -f "$item" ]]; then
            script_path="$item"
        elif [[ -d "$item" ]]; then
            script_path="$item/run.sh"
            if [[ -L "$script_path" && ! -e "$script_path" ]]; then
                doctor_fail "$repo_name: cleanup '$cleanup_id' run.sh is a broken symlink"
                continue
            fi
            if [[ ! -f "$script_path" ]]; then
                doctor_fail "$repo_name: cleanup '$cleanup_id' is missing run.sh"
                continue
            fi
        else
            doctor_fail "$repo_name: cleanup '$cleanup_id' is not a file or directory"
            continue
        fi

        if [[ ! -x "$script_path" ]]; then
            doctor_fail "$repo_name: cleanup '$cleanup_id' exists but is not executable"
            continue
        fi

        if [[ -d "$item" && -e "$item/config" ]]; then
            if [[ -L "$item/config" && ! -e "$item/config" ]]; then
                doctor_fail "$repo_name: cleanup '$cleanup_id' config is a broken symlink"
                continue
            fi
            if [[ ! -f "$item/config" ]]; then
                doctor_fail "$repo_name: cleanup '$cleanup_id' config is not a file"
                continue
            fi
            if ! _load_cleanup_config_file "$item/config"; then
                doctor_fail "$repo_name: cleanup '$cleanup_id' config is invalid: ${_CLEANUP_CONFIG_LOAD_ERROR:-unknown error}"
                continue
            fi
        fi

        doctor_success "$repo_name: cleanup '$cleanup_id' is valid"
    done

    if [[ "$found_cleanups" == "false" ]]; then
        doctor_success "$repo_name: no cleanup tasks"
    fi
}

# Commands

cmd_install() {
    local source="${1:-}"

    registry_init
    rm -f "$DOTTY_DIR/.needs-reload"
    _DOTTY_CHANGES_MADE=false

    if [[ -z "$source" ]]; then
        # No argument: re-run install on existing repos
        self_update
        resolve_chain_from_leaf
        run_chain "true" "install"
    else
        local repo_dir
        if [[ -d "$source" ]]; then
            repo_dir="$(cd "$source" && pwd)"
        else
            local source_basename
            source_basename="$(basename "$source" .git)"
            repo_dir="$(ensure_repo "$source" "$HOME/$source_basename")"
        fi

        # Resolve full chain
        CHAIN_NAMES=()
        CHAIN_PATHS=()
        _RESOLVING=()
        resolve_chain "$repo_dir"

        run_chain "true" "install"
    fi

    _write_reload_marker
    [[ "$_CHAIN_HAD_ERRORS" != "true" ]] && success "Install complete!"
    cmd_status
}

cmd_update() {
    local target="${1:-}"

    registry_init
    rm -f "$DOTTY_DIR/.needs-reload"
    _DOTTY_CHANGES_MADE=false
    self_update

    if [[ -n "$target" ]]; then
        # Update a single repo, but re-run full chain
        local path
        path="$(registry_get "$target")" || true
        [[ -n "$path" ]] || die "Unknown repo: $target"
        [[ -d "$path" ]] || die "Repo directory not found: $path"

        pull_if_clean "$path"

        # Resolve full chain from the leaf repo
        resolve_chain_from_leaf
        run_chain "false" "update"
    else
        resolve_chain_from_leaf
        run_chain "true" "update"
    fi

    _write_reload_marker
    [[ "$_CHAIN_HAD_ERRORS" != "true" ]] && success "Update complete!"
}

cmd_link() {
    local target="${1:-}"

    registry_init

    if [[ -n "$target" ]]; then
        local path
        path="$(registry_get "$target")" || true
        [[ -n "$path" ]] || die "Unknown repo: $target"

        CHAIN_NAMES=()
        CHAIN_PATHS=()
        _RESOLVING=()
        resolve_chain "$path"
    else
        resolve_chain_from_leaf
    fi

    local env
    env="$(detect_environment)"
    [[ -n "$env" ]] && info "Detected environment: $env"

    _HOOK_ERRORS=()
    _LINK_FAIL_COUNT=0

    local i
    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        local dir="${CHAIN_PATHS[$i]}"
        process_repo "$dir" "$env" "link"
    done

    if [[ $_LINK_FAIL_COUNT -gt 0 ]]; then
        warning "$_LINK_FAIL_COUNT symlink(s) failed to create"
    else
        success "Linking complete!"
    fi
}

cmd_cleanups() {
    local include_all=false
    local pending_only=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)
                include_all=true
                shift
                ;;
            --pending)
                pending_only=true
                shift
                ;;
            *)
                die "Usage: dotty cleanups [--all] [--pending]"
                ;;
        esac
    done

    registry_init
    resolve_chain_from_leaf

    local env=""
    env="$(detect_environment 2>/dev/null)" || true

    local machine_id=""
    machine_id="$(_current_machine_id 2>/dev/null)" || true

    title "dotty cleanups"
    if [[ -n "$env" ]]; then
        echo -e "Env:     ${COLOR_GREEN}$env${COLOR_NONE}"
    fi
    if [[ -n "$machine_id" ]]; then
        echo -e "Machine: ${COLOR_GREEN}$machine_id${COLOR_NONE}"
    fi

    local printed_any=false
    local i
    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        local repo_name="${CHAIN_NAMES[$i]}"
        local repo_dir="${CHAIN_PATHS[$i]}"
        local cleanups_dir
        cleanups_dir="$(_find_cleanups_dir "$repo_dir")" || continue

        local -a lines=()
        local cleanup_path
        for cleanup_path in "$cleanups_dir"/*; do
            [[ -e "$cleanup_path" || -L "$cleanup_path" ]] || continue

            local cleanup_id
            cleanup_id="$(basename "$cleanup_path")"
            [[ "$cleanup_id" == .* ]] && continue

            local description=""
            local applicability="applicable"
            local reason=""

            if ! _cleanup_metadata_load "$cleanup_path"; then
                description="${_CLEANUP_CONFIG_LOAD_ERROR:-invalid config}"
                applicability="not applicable"
                reason="invalid config"
            else
                description="$DOTTY_CLEANUP_DESCRIPTION"
                if ! _cleanup_applies_to_env "$env" || ! _cleanup_applies_to_machine "$machine_id"; then
                    applicability="not applicable"
                    reason="$(_cleanup_not_applicable_reason "$env" "$machine_id")"
                fi
            fi

            local status
            status="$(_cleanup_status "$repo_name" "$cleanup_id")"

            if [[ "$applicability" != "applicable" ]]; then
                if [[ "$include_all" != "true" && "${DOTTY_VERBOSE:-false}" != "true" ]]; then
                    continue
                fi
                status="not applicable"
            fi

            if [[ "$pending_only" == "true" && "$status" != "pending" ]]; then
                continue
            fi

            local line="  $status  $cleanup_id"
            if [[ -n "$description" ]]; then
                line+="  $description"
            fi
            if [[ -n "$reason" && "$status" == "not applicable" ]]; then
                line+=" ($reason)"
            fi
            lines+=("$line")
        done

        if [[ ${#lines[@]} -eq 0 ]]; then
            continue
        fi

        echo ""
        title "$repo_name"
        printf '%s\n' "${lines[@]}"
        printed_any=true
    done

    if [[ "$printed_any" == "false" ]]; then
        info "No cleanup tasks found."
    fi
}

_resolve_repo_command() {
    local target_name="$1"
    local i repo_dir="" repo_name="" candidate=""
    local found_repo_name="" found_repo_dir="" found_path="" found_executable="false"

    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        repo_dir="${CHAIN_PATHS[$i]}"
        repo_name="${CHAIN_NAMES[$i]}"
        candidate="$repo_dir/.dotty/commands/$target_name"

        if [[ -e "$candidate" ]]; then
            found_repo_name="$repo_name"
            found_repo_dir="$repo_dir"
            found_path="$candidate"

            if [[ -f "$candidate" && -x "$candidate" ]]; then
                found_executable="true"
            else
                found_executable="false"
            fi
        fi
    done

    [[ -n "$found_path" ]] || return 1
    printf '%s\t%s\t%s\t%s\n' "$found_repo_name" "$found_repo_dir" "$found_path" "$found_executable"
}

_resolved_repo_command_records() {
    local -a names=() repo_names=() repo_dirs=() paths=() executable=()
    local i repo_dir="" repo_name="" commands_dir="" item="" name="" index=-1

    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        repo_dir="${CHAIN_PATHS[$i]}"
        repo_name="${CHAIN_NAMES[$i]}"
        commands_dir="$(_find_commands_dir "$repo_dir")" || continue

        for item in "$commands_dir"/*; do
            [[ -e "$item" ]] || continue
            [[ -f "$item" ]] || continue

            name="$(basename "$item")"
            [[ "$name" == .* ]] && continue

            index=-1
            local existing_index
            for existing_index in "${!names[@]}"; do
                if [[ "${names[$existing_index]}" == "$name" ]]; then
                    index="$existing_index"
                    break
                fi
            done

            if (( index < 0 )); then
                names+=("$name")
                repo_names+=("")
                repo_dirs+=("")
                paths+=("")
                executable+=("false")
                index=$((${#names[@]} - 1))
            fi

            names[$index]="$name"
            repo_names[$index]="$repo_name"
            repo_dirs[$index]="$repo_dir"
            paths[$index]="$item"
            if [[ -x "$item" ]]; then
                executable[$index]="true"
            else
                executable[$index]="false"
            fi
        done
    done

    local output=""
    for i in "${!names[@]}"; do
        [[ "${executable[$i]}" == "true" ]] || continue
        output+="${names[$i]}"$'\t'"${repo_names[$i]}"$'\t'"${repo_dirs[$i]}"$'\t'"${paths[$i]}"$'\n'
    done

    printf '%s' "$output" | LC_ALL=C sort
}

cmd_commands() {
    [[ $# -eq 0 ]] || die "Usage: dotty commands"

    registry_init
    resolve_chain_from_leaf

    local records=""
    records="$(_resolved_repo_command_records)"
    [[ -n "$records" ]] || return 0

    while IFS=$'\t' read -r name repo_name _repo_dir _path || [[ -n "${name:-}${repo_name:-}" ]]; do
        [[ -n "${name}" ]] || continue
        printf '%s\t%s\n' "$name" "$repo_name"
    done <<< "$records"
}

cmd_run() {
    local target_name="${1:-}"
    [[ -n "$target_name" ]] || die "Usage: dotty run <name> [args]"
    shift || true

    registry_init
    resolve_chain_from_leaf

    local repo_name="" repo_dir="" command_path="" executable="false"
    if ! IFS=$'\t' read -r repo_name repo_dir command_path executable < <(_resolve_repo_command "$target_name"); then
        die "Unknown repo-defined command: $target_name"
    fi

    [[ "$executable" == "true" ]] || die "Command '$target_name' exists but is not executable: $command_path"

    if [[ "${DOTTY_DRY_RUN:-false}" == "true" ]]; then
        info "[dry-run] Would run command '$target_name' from $repo_name"
        return 0
    fi

    local env=""
    env="$(detect_environment)"

    export DOTTY_COMMAND="run"
    export DOTTY_RUN_NAME="$target_name"
    export DOTTY_RUN_REPO="$repo_dir"
    export DOTTY_ENV="${env:-}"
    export DOTTY_VERBOSE
    export DOTTY_DRY_RUN
    export DOTTY_LIB
    DOTTY_LIB="$(cd "$(dirname "$0")" && pwd)/lib/utils.sh"

    cd "$repo_dir"
    exec "$command_path" "$@"
}

cmd_uninstall() {
    local target_name="${1:-}"
    [[ -n "$target_name" ]] || die "Usage: dotty uninstall <name>"

    registry_init

    local target_path
    target_path="$(registry_get "$target_name")" || true
    [[ -n "$target_path" ]] || die "Unknown repo: $target_name"

    read_config "$target_path"

    title "Uninstalling $target_name"

    # Remove symlinks from home/
    if [[ -d "$target_path/home" ]]; then
        remove_repo_symlinks "$target_path/home" "$HOME"
    fi

    # Remove symlinks from environment overlay
    local env=""
    if [[ ${#CHAIN_PATHS[@]} -eq 0 ]]; then
        # Resolve chain so we can detect environment
        CHAIN_NAMES=()
        CHAIN_PATHS=()
        _RESOLVING=()
        resolve_chain_from_leaf 2>/dev/null || true
    fi
    env="$(detect_environment 2>/dev/null)" || true
    if [[ -n "$env" && ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && _is_declared_env "$env"; then
        if [[ -d "$target_path/$env/home" ]]; then
            remove_repo_symlinks "$target_path/$env/home" "$HOME"
        fi
    fi

    local summary="${_UNLINK_COUNT} symlink(s) removed"
    if [[ $_RESTORE_COUNT -gt 0 ]]; then
        summary+=", ${_RESTORE_COUNT} file(s) restored from backup"
    fi
    info "$summary"

    # Unregister
    if [[ "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
        registry_remove "$target_name"
    else
        info "[dry-run] Would unregister $target_name"
    fi

    success "Uninstalled $target_name"
}

cmd_add() {
    local file=""
    local repo_name=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo)
                [[ $# -ge 2 ]] || die "Usage: dotty add <file> [--repo <name>]"
                repo_name="$2"
                shift 2
                ;;
            --repo=*)
                repo_name="${1#--repo=}"
                shift
                ;;
            *)
                file="$1"
                shift
                ;;
        esac
    done

    [[ -n "$file" ]] || die "Usage: dotty add <file> [--repo <name>]"
    [[ -e "$file" ]] || die "File not found: $file"
    [[ -L "$file" ]] && die "Already a symlink: $file"

    registry_init

    local abs_file
    abs_file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"

    local repo_path=""
    if [[ -n "$repo_name" ]]; then
        repo_path="$(registry_get "$repo_name")" || true
        [[ -n "$repo_path" ]] || die "Unknown repo: $repo_name"
    else
        local count
        count="$(wc -l < "$DOTTY_REGISTRY" | tr -d ' ')"

        if [[ "$count" -eq 0 ]]; then
            die "No repos registered. Run 'dotty install' first."
        elif [[ "$count" -eq 1 ]]; then
            repo_name="$(cut -d= -f1 "$DOTTY_REGISTRY")"
            repo_path="$(cut -d= -f2- "$DOTTY_REGISTRY")"
        else
            echo "Multiple repos registered. Which one?"
            local i=1
            while IFS='=' read -r name rpath; do
                echo "  $i) $name ($rpath)"
                i=$((i + 1))
            done < "$DOTTY_REGISTRY"
            echo -n "Choice: "
            read -r choice
            repo_name="$(sed -n "${choice}p" "$DOTTY_REGISTRY" | cut -d= -f1)"
            repo_path="$(sed -n "${choice}p" "$DOTTY_REGISTRY" | cut -d= -f2-)"
        fi
    fi

    [[ -d "$repo_path" ]] || die "Repo directory not found: $repo_path"

    local rel_path="${abs_file#"$HOME"/}"
    [[ "$rel_path" != "$abs_file" ]] || die "File must be under \$HOME: $abs_file"
    local dest="$repo_path/home/$rel_path"
    [[ ! -e "$dest" && ! -L "$dest" ]] || die "Target already exists in repo: $dest"

    mkdir -p "$(dirname "$dest")"
    mv "$abs_file" "$dest"
    ln -s "$dest" "$abs_file"

    success "Moved: ~/$rel_path → $repo_name/home/$rel_path"
    success "Linked: ~/$rel_path"
    echo ""
    info "Don't forget to commit the new file:"
    echo -e "${COLOR_DIM}cd $repo_path && git add home/$rel_path${COLOR_NONE}"
}

cmd_status() {
    registry_init

    title "dotty status"

    local count=0
    local repos=()
    while IFS='=' read -r name rpath; do
        [[ -n "$name" ]] || continue
        repos+=("$name=$rpath")
        count=$((count + 1))
    done < "$DOTTY_REGISTRY"

    if [[ $count -eq 0 ]]; then
        info "No repos registered."
        return 0
    fi

    resolve_chain_from_leaf

    if [[ ${#CHAIN_NAMES[@]} -gt 0 ]]; then
        local chain_str=""
        for (( i=0; i<${#CHAIN_NAMES[@]}; i++ )); do
            [[ -n "$chain_str" ]] && chain_str+=" → "
            chain_str+="${CHAIN_NAMES[$i]}"
        done
        echo -e "Chain: ${COLOR_GREEN}$chain_str${COLOR_NONE}"
    fi

    local env=""
    if [[ ${#CHAIN_PATHS[@]} -gt 0 ]]; then
        env="$(detect_environment 2>/dev/null)" || true
    fi
    if [[ -n "$env" ]]; then
        echo -e "Env:   ${COLOR_GREEN}$env${COLOR_NONE}"

        local overlay_repos=()
        for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
            if [[ -d "${CHAIN_PATHS[$i]}/$env/home" ]]; then
                if _has_config "${CHAIN_PATHS[$i]}"; then
                    read_config "${CHAIN_PATHS[$i]}"
                    if [[ ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && _is_declared_env "$env"; then
                        overlay_repos+=("${CHAIN_NAMES[$i]}")
                    fi
                fi
            fi
        done
        if [[ ${#overlay_repos[@]} -gt 0 ]]; then
            echo -e "         ${COLOR_DIM}overlays: ${overlay_repos[*]}${COLOR_NONE}"
        fi
    fi

    echo ""

    for entry in "${repos[@]}"; do
        local name="${entry%%=*}"
        local rpath="${entry#*=}"

        local status_icon="?"
        local status_text="unknown"
        if [[ -d "$rpath/.git" ]]; then
            if (cd "$rpath" && git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null); then
                status_icon="${COLOR_GREEN}✓${COLOR_NONE}"
                status_text="clean"
            else
                status_icon="${COLOR_YELLOW}●${COLOR_NONE}"
                status_text="modified"
            fi
        elif [[ -d "$rpath" ]]; then
            status_icon="${COLOR_DIM}-${COLOR_NONE}"
            status_text="not a git repo"
        else
            status_icon="${COLOR_RED}✗${COLOR_NONE}"
            status_text="missing"
        fi

        # Count symlink health
        local linked=0 overridden=0 not_linked=0
        _FILE_LINES=()
        if _has_config "$rpath"; then
            read_config "$rpath"
        else
            _reset_config_state
        fi
        _files_walk "$rpath/home" "" "$name"
        if [[ -n "$env" && -d "$rpath/$env/home" ]]; then
            if [[ ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && _is_declared_env "$env"; then
                _files_walk "$rpath/$env/home" "" "$name"
            fi
        fi
        for fl in ${_FILE_LINES[@]+"${_FILE_LINES[@]}"}; do
            case "${fl%%|*}" in
                linked)     linked=$((linked + 1)) ;;
                overridden) overridden=$((overridden + 1)) ;;
                not_linked) not_linked=$((not_linked + 1)) ;;
            esac
        done

        local link_summary="${linked} linked"
        if [[ $overridden -gt 0 ]]; then
            link_summary+=", ${overridden} overridden"
        fi
        if [[ $not_linked -gt 0 ]]; then
            link_summary+=", ${not_linked} unlinked"
        fi

        echo -e "$status_icon $name ${COLOR_DIM}($rpath) [$status_text] [$link_summary]${COLOR_NONE}"
    done
}

cmd_register() {
    local path="${1:-}"
    local name="${2:-}"

    [[ -n "$path" ]] || die "Usage: dotty register <path> [name]"

    registry_init

    [[ -d "$path" ]] || die "Directory not found: $path"
    path="$(cd "$path" && pwd)"

    if [[ -z "$name" ]]; then
        local conf
        conf="$(_find_config "$path")" || die "No .dotty/config found and no name provided"
        name="$(DOTTY_NAME=""; source "$conf"; echo "$DOTTY_NAME")"
        [[ -n "$name" ]] || die "DOTTY_NAME not set in $conf"
    fi

    registry_set "$name" "$path"
    success "Registered $name → $path"
}

cmd_unregister() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "Usage: dotty unregister <name>"

    registry_init

    local path
    path="$(registry_get "$name")" || true
    [[ -n "$path" ]] || die "Unknown repo: $name"

    registry_remove "$name"
    success "Unregistered $name"
}

_resolve_script_dir() {
    # Resolve through symlinks so this works when invoked via ~/.dotty/bin/dotty.
    local script="$0"
    while [[ -L "$script" ]]; do
        local target
        target="$(readlink "$script")"
        if [[ "$target" == /* ]]; then
            script="$target"
        else
            script="$(dirname "$script")/$target"
        fi
    done
    (cd "$(dirname "$script")" && pwd)
}

_guard_check_usage() {
    cat <<'EOF'
Usage: dotty guard-check [--staged|--worktree] [--patterns-file PATH] [--exclude PATH] [PATH...]

Blocks added public-repo lines that match configured sensitive-content patterns.

Pattern sources:
  - repo .githooks/sensitive-content-patterns when present
  - $XDG_CONFIG_HOME/public-content-guard/patterns when present
  - colon-separated $PUBLIC_CONTENT_GUARD_PATTERN_FILE paths
  - newline-separated $PUBLIC_CONTENT_GUARD_PATTERNS entries

Set PUBLIC_CONTENT_GUARD_SKIP=1 to disable the guard.
EOF
}

_guard_check_trim() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "$value"
}

_GUARD_CHECK_PATTERNS=()

_guard_check_append_pattern() {
    local pattern
    pattern="$(_guard_check_trim "$1")"
    [[ -z "$pattern" || "$pattern" == \#* ]] && return
    _GUARD_CHECK_PATTERNS+=("$pattern")
}

_guard_check_load_patterns_file() {
    local path="$1"
    local line

    [[ -f "$path" ]] || return 0
    while IFS= read -r line || [[ -n "$line" ]]; do
        _guard_check_append_pattern "$line"
    done < "$path"
}

_guard_check_combined_patterns() {
    local pattern
    local combined=""

    for pattern in "${_GUARD_CHECK_PATTERNS[@]+"${_GUARD_CHECK_PATTERNS[@]}"}"; do
        [[ -n "$combined" ]] && combined+="|"
        combined+="$pattern"
    done

    printf '%s' "$combined"
}

_guard_check_repo_root() {
    git rev-parse --show-toplevel 2>/dev/null || pwd
}

cmd_guard_check() {
    local mode="staged"
    local -a paths=()
    local -a excludes=()
    local -a pattern_files=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --staged)
                mode="staged"
                ;;
            --worktree)
                mode="worktree"
                ;;
            --patterns-file)
                [[ $# -ge 2 ]] || die "--patterns-file requires a path"
                pattern_files+=("$2")
                shift
                ;;
            --exclude)
                [[ $# -ge 2 ]] || die "--exclude requires a path"
                excludes+=("$2")
                shift
                ;;
            -h|--help)
                _guard_check_usage
                return 0
                ;;
            --)
                shift
                while [[ $# -gt 0 ]]; do
                    paths+=("$1")
                    shift
                done
                break
                ;;
            -*)
                die "unknown argument: $1"
                ;;
            *)
                paths+=("$1")
                ;;
        esac
        shift
    done

    [[ "${PUBLIC_CONTENT_GUARD_SKIP:-0}" == "1" ]] && return 0

    local repo_root
    repo_root="$(_guard_check_repo_root)"

    local default_repo_patterns="$repo_root/.githooks/sensitive-content-patterns"
    local default_user_patterns="${XDG_CONFIG_HOME:-$HOME/.config}/public-content-guard/patterns"

    _GUARD_CHECK_PATTERNS=()
    pattern_files=("$default_repo_patterns" "$default_user_patterns" "${pattern_files[@]+"${pattern_files[@]}"}")

    if [[ -n "${PUBLIC_CONTENT_GUARD_PATTERN_FILE:-}" ]]; then
        local -a env_pattern_files=()
        IFS=':' read -r -a env_pattern_files <<< "$PUBLIC_CONTENT_GUARD_PATTERN_FILE"
        pattern_files+=("${env_pattern_files[@]}")
    fi

    local pattern_file
    for pattern_file in "${pattern_files[@]+"${pattern_files[@]}"}"; do
        _guard_check_load_patterns_file "$pattern_file"
    done

    if [[ -n "${PUBLIC_CONTENT_GUARD_PATTERNS:-}" ]]; then
        local pattern
        while IFS= read -r pattern || [[ -n "$pattern" ]]; do
            _guard_check_append_pattern "$pattern"
        done <<< "$PUBLIC_CONTENT_GUARD_PATTERNS"
    fi

    local combined
    combined="$(_guard_check_combined_patterns)"
    [[ -n "$combined" ]] || return 0

    local -a git_paths=()
    if [[ ${#paths[@]} -gt 0 ]]; then
        git_paths+=("--" "${paths[@]}")
    else
        git_paths+=("--" ".")
    fi

    local excluded
    for excluded in "${excludes[@]+"${excludes[@]}"}"; do
        git_paths+=(":(exclude)$excluded")
    done

    local matches=""

    case "$mode" in
        staged)
            local staged_files
            staged_files="$(git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR "${git_paths[@]}")"
            [[ -n "$staged_files" ]] || return 0

            local file
            while IFS= read -r file; do
                [[ -n "$file" ]] || continue

                local file_matches
                file_matches="$(git -C "$repo_root" diff --cached --unified=0 --no-color -- "$file" | grep -iE "^\+[^+].*($combined)" || true)"
                [[ -n "$file_matches" ]] || continue

                local line
                while IFS= read -r line; do
                    [[ -n "$line" ]] || continue
                    matches+="$file: $line"$'\n'
                done <<< "$file_matches"
            done <<< "$staged_files"
            ;;
        worktree)
            local tracked_files
            tracked_files="$(git -C "$repo_root" ls-files "${git_paths[@]}")"
            [[ -n "$tracked_files" ]] || return 0

            local file
            while IFS= read -r file; do
                [[ -n "$file" && -f "$repo_root/$file" ]] || continue

                local file_matches
                file_matches="$(grep -iEn "$combined" "$repo_root/$file" || true)"
                [[ -n "$file_matches" ]] || continue

                local line
                while IFS= read -r line; do
                    [[ -n "$line" ]] || continue
                    matches+="$file: $line"$'\n'
                done <<< "$file_matches"
            done <<< "$tracked_files"
            ;;
        *)
            die "unknown mode: $mode"
            ;;
    esac

    if [[ -n "$matches" ]]; then
        printf '\n'
        printf '  Commit blocked. Added lines contain content this public repo should not mention.\n'
        printf '\n'
        printf '  Matches found:\n'
        printf '\n'
        printf '%s' "$matches" | head -20 | while IFS= read -r line; do
            printf '    %s\n' "$line"
        done

        local local_count
        local_count="$(printf '%s' "$matches" | wc -l | tr -d ' ')"
        if [[ "$local_count" -gt 20 ]]; then
            printf '    ... and %s more\n' "$((local_count - 20))"
        fi

        printf '\n'
        printf '  Remove or reword the added text, or bypass the guard if this is intentional.\n'
        printf '\n'
        return 1
    fi
}

_guard_hook_path() {
    local script_dir
    script_dir="$(_resolve_script_dir)"

    if [[ -f "$script_dir/hooks/pre-commit" ]]; then
        echo "$script_dir/hooks/pre-commit"
    else
        die "Cannot find hooks/pre-commit relative to dotty script ($script_dir)"
    fi
}

_guard_is_ours() {
    local hook="$1"
    [[ -f "$hook" ]] && grep -q "dotty guard" "$hook" 2>/dev/null
}

_guard_dotty_command() {
    local command_path="$0"
    if [[ "$command_path" == */* ]]; then
        local command_dir
        command_dir="$(cd "$(dirname "$command_path")" && pwd)"
        printf '%s/%s\n' "$command_dir" "$(basename "$command_path")"
    else
        command -v "$command_path"
    fi
}

_guard_sed_replacement() {
    printf '%s' "$1" | sed 's/[\\\/&]/\\&/g'
}

_install_guard_hook() {
    local hook_src="$1"
    local hook_dest="$2"
    local dotty_command
    local dotty_literal
    local dotty_replacement

    dotty_command="$(_guard_dotty_command)"
    printf -v dotty_literal '%q' "$dotty_command"
    dotty_replacement="$(_guard_sed_replacement "$dotty_literal")"

    sed "s/__DOTTY_COMMAND_LITERAL__/$dotty_replacement/g" "$hook_src" > "$hook_dest"
    chmod +x "$hook_dest"
}

_guard_pattern_hint() {
    if [[ -n "${PUBLIC_CONTENT_GUARD_PATTERNS:-}" ]]; then
        local count=0
        while IFS= read -r line; do
            line="${line## }"
            line="${line%% }"
            [[ -z "$line" || "$line" == \#* ]] && continue
            count=$((count + 1))
        done <<< "$PUBLIC_CONTENT_GUARD_PATTERNS"
        info "PUBLIC_CONTENT_GUARD_PATTERNS has $count pattern(s) configured."
    else
        local user_patterns="${XDG_CONFIG_HOME:-$HOME/.config}/public-content-guard/patterns"
        if [[ -f "$user_patterns" || -n "${PUBLIC_CONTENT_GUARD_PATTERN_FILE:-}" ]]; then
            info "Public content guard pattern file configuration is available."
        else
            warning "No public content guard patterns are configured yet."
        fi
    fi
}

cmd_guard() {
    local target="${1:-.}"

    [[ -d "$target" ]] || die "Directory not found: $target"
    target="$(cd "$target" && pwd)"
    [[ -d "$target/.git" ]] || die "Not a git repository: $target"

    local hook_dest="$target/.git/hooks/pre-commit"
    local hook_src
    hook_src="$(_guard_hook_path)"

    if [[ -f "$hook_dest" ]]; then
        if _guard_is_ours "$hook_dest"; then
            # Always re-copy to pick up hook updates.
            _install_guard_hook "$hook_src" "$hook_dest"
            success "Guard hook updated in $target"
            _guard_pattern_hint
            return 0
        fi

        warning "A pre-commit hook already exists in $target"
        echo -n "  Overwrite it? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy]$ ]] || { info "Aborted."; return 1; }
    fi

    mkdir -p "$target/.git/hooks"
    _install_guard_hook "$hook_src" "$hook_dest"

    success "Guard hook installed in $target"
    _guard_pattern_hint
}

cmd_unguard() {
    local target="${1:-.}"

    [[ -d "$target" ]] || die "Directory not found: $target"
    target="$(cd "$target" && pwd)"
    [[ -d "$target/.git" ]] || die "Not a git repository: $target"

    local hook="$target/.git/hooks/pre-commit"

    if [[ ! -f "$hook" ]]; then
        info "No pre-commit hook found in $target"
        return 0
    fi

    if ! _guard_is_ours "$hook"; then
        warning "The pre-commit hook in $target was not installed by dotty."
        echo -n "  Remove it anyway? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy]$ ]] || { info "Aborted."; return 1; }
    fi

    rm "$hook"
    success "Guard hook removed from $target"
}

_FILE_LINES=()

# Check if a $HOME path is managed by dotty, either as a direct symlink
# or via a parent directory that is symlinked into a repo.
_is_managed() {
    local home_path="$1"
    local source_item="$2"

    # Direct symlink pointing to the source item
    if [[ -L "$home_path" ]]; then
        local link_target
        link_target="$(readlink "$home_path")"
        if [[ "$link_target" == "$source_item" ]]; then
            echo "linked"
            return 0
        else
            echo "overridden"
            return 0
        fi
    fi

    # Check if a parent directory is a symlink into a repo
    local check="$home_path"
    while [[ "$check" != "$HOME" && "$check" != "/" ]]; do
        check="$(dirname "$check")"
        if [[ -L "$check" ]]; then
            # Parent is a symlink — check if the file is accessible through it
            if [[ -e "$home_path" ]]; then
                echo "linked"
                return 0
            fi
            break
        fi
    done

    echo "not_linked"
}

_files_walk() {
    local source_dir="$1"
    local prefix="$2"
    local repo_name="$3"

    [[ -d "$source_dir" ]] || return 0

    local item
    for item in "$source_dir"/* "$source_dir"/.*; do
        [[ -e "$item" ]] || continue
        local name
        name="$(basename "$item")"
        [[ "$name" == "." || "$name" == ".." ]] && continue
        should_exclude "$name" && continue

        local rel="${prefix:+$prefix/}$name"
        _is_link_ignored "$rel" && continue
        _is_gitignored "$item" && continue

        local home_path="$HOME/$rel"

        if [[ -d "$item" && ! -L "$item" ]]; then
            _files_walk "$item" "$rel" "$repo_name"
        else
            local status
            status="$(_is_managed "$home_path" "$item")"
            _FILE_LINES+=("$status|$rel|$repo_name")
        fi
    done
}

cmd_files() {
    local filter_repo="${1:-}"

    registry_init

    local -a all_names=()
    local -a all_paths=()
    while IFS='=' read -r name rpath; do
        [[ -n "$name" ]] || continue
        if [[ -n "$filter_repo" && "$name" != "$filter_repo" ]]; then
            continue
        fi
        all_names+=("$name")
        all_paths+=("$rpath")
    done < "$DOTTY_REGISTRY"

    if [[ ${#all_names[@]} -eq 0 ]]; then
        if [[ -n "$filter_repo" ]]; then
            die "Unknown repo: $filter_repo"
        fi
        info "No repos registered."
        return 0
    fi

    # Detect environment for overlay scanning
    local env=""
    env="$(detect_environment 2>/dev/null)" || true

    _FILE_LINES=()

    for (( i=0; i<${#all_names[@]}; i++ )); do
        local name="${all_names[$i]}"
        local rpath="${all_paths[$i]}"

        if _has_config "$rpath"; then
            read_config "$rpath"
        else
            _reset_config_state
        fi
        _files_walk "$rpath/home" "" "$name"

        # Environment overlay
        if [[ -n "$env" && -d "$rpath/$env/home" ]]; then
            if [[ ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && _is_declared_env "$env"; then
                _files_walk "$rpath/$env/home" "" "$name"
            fi
        fi
    done

    if [[ ${#_FILE_LINES[@]} -eq 0 ]]; then
        info "No managed files found."
        return 0
    fi

    # Group by repo, show status
    local current_repo=""
    # Sort by repo name then path
    local -a sorted
    IFS=$'\n' sorted=($(printf '%s\n' ${_FILE_LINES[@]+"${_FILE_LINES[@]}"} | sort -t'|' -k3,3 -k2,2))
    unset IFS

    for line in "${sorted[@]}"; do
        local status="${line%%|*}"
        local rest="${line#*|}"
        local rel="${rest%%|*}"
        local repo="${rest#*|}"

        if [[ "$repo" != "$current_repo" ]]; then
            [[ -n "$current_repo" ]] && echo ""
            title "$repo"
            current_repo="$repo"
        fi

        case "$status" in
            linked)
                echo -e "${COLOR_GREEN}✓ ~/$rel${COLOR_NONE}"
                ;;
            overridden)
                echo -e "${COLOR_DIM}○ ~/$rel (overridden)${COLOR_NONE}"
                ;;
            not_linked)
                echo -e "${COLOR_YELLOW}● ~/$rel (not linked)${COLOR_NONE}"
                ;;
        esac
    done
}

cmd_trace() {
    local target="${1:-}"
    [[ -n "$target" ]] || die "Usage: dotty trace <path>"

    registry_init

    # Expand ~ and resolve to absolute path (but don't follow symlinks yet)
    if [[ "$target" == "~/"* ]]; then
        target="$HOME/${target#\~/}"
    fi
    if [[ "$target" != /* ]]; then
        target="$(pwd)/$target"
    fi

    if [[ ! -e "$target" && ! -L "$target" ]]; then
        die "Path does not exist: $target"
    fi

    local display="~${target#"$HOME"}"

    if [[ ! -L "$target" ]]; then
        # Not a symlink — check if it's a directory with dotty-managed contents
        if [[ -d "$target" ]]; then
            local found=0
            local item
            for item in "$target"/* "$target"/.*; do
                [[ -e "$item" || -L "$item" ]] || continue
                local iname
                iname="$(basename "$item")"
                [[ "$iname" == "." || "$iname" == ".." ]] && continue
                [[ -L "$item" ]] || continue

                local link_target
                link_target="$(readlink "$item")"

                while IFS='=' read -r name rpath; do
                    [[ -n "$name" ]] || continue
                    if [[ "$link_target" == "$rpath/home/"* || "$link_target" == "$rpath/"*/home/* ]]; then
                        local rel="${link_target#"$rpath"/}"
                        echo -e "~${item#"$HOME"}  →  ${COLOR_GREEN}$name${COLOR_NONE} ($rel)"
                        found=$((found + 1))
                    fi
                done < "$DOTTY_REGISTRY"
            done
            if [[ $found -eq 0 ]]; then
                info "$display is a directory not managed by dotty"
            fi
        else
            info "$display is not a symlink (not managed by dotty)"
        fi
        return 0
    fi

    # It's a symlink — resolve and match against repos
    local link_target
    link_target="$(readlink "$target")"

    local matched=0
    while IFS='=' read -r name rpath; do
        [[ -n "$name" ]] || continue
        if [[ "$link_target" == "$rpath/home/"* || "$link_target" == "$rpath/"*/home/* ]]; then
            local rel="${link_target#"$rpath"/}"
            echo -e "$display  →  ${COLOR_GREEN}$name${COLOR_NONE} ($rel)"
            matched=1
            break
        fi
    done < "$DOTTY_REGISTRY"

    if [[ $matched -eq 0 ]]; then
        # Symlink exists but doesn't point into any registered repo
        info "$display → $link_target (not managed by dotty)"
    fi
}

cmd_doctor() {
    [[ $# -eq 0 ]] || die "Usage: dotty doctor"

    registry_init
    title "dotty doctor"

    _DOCTOR_FAIL_COUNT=0
    _DOCTOR_WARN_COUNT=0

    local repo_count=0
    local -a valid_repo_paths=()

    while IFS='=' read -r registered_name repo_path; do
        [[ -n "$registered_name" ]] || continue
        repo_count=$((repo_count + 1))

        if [[ ! -d "$repo_path" ]]; then
            doctor_fail "$registered_name: registered path is missing ($repo_path)"
            continue
        fi
        doctor_success "$registered_name: registered path exists"

        if ! _doctor_read_config "$repo_path"; then
            doctor_fail "$registered_name: ${_DOCTOR_ERROR}"
            continue
        fi

        local resolved_name="$DOTTY_NAME"
        if [[ "$resolved_name" != "$registered_name" ]]; then
            doctor_fail "$registered_name: registry name does not match DOTTY_NAME ($resolved_name)"
        else
            doctor_success "$registered_name: config loads cleanly"
        fi

        if [[ ! -d "$repo_path/.git" ]]; then
            doctor_warn "$registered_name: not a git repo, update and check will skip git operations"
        fi

        _doctor_check_hook "$registered_name" "$repo_path"
        _doctor_check_commands "$registered_name" "$repo_path"
        _doctor_check_cleanups "$registered_name" "$repo_path"
        valid_repo_paths+=("$repo_path")
    done < "$DOTTY_REGISTRY"

    if [[ $repo_count -eq 0 ]]; then
        doctor_fail "No repos registered. Run 'dotty install' first."
    fi

    local repo_dir
    for repo_dir in "${valid_repo_paths[@]}"; do
        if ! _doctor_read_config "$repo_dir"; then
            continue
        fi

        local leaf_name="$DOTTY_NAME"
        _DOCTOR_CHAIN_NAMES=()
        _DOCTOR_CHAIN_PATHS=()
        _DOCTOR_RESOLVING=()
        _DOCTOR_ERROR=""

        if ! _doctor_resolve_chain_no_clone "$repo_dir"; then
            doctor_fail "$leaf_name: ${_DOCTOR_ERROR}"
            continue
        fi

        local chain_str=""
        local chain_name
        for chain_name in ${_DOCTOR_CHAIN_NAMES[@]+"${_DOCTOR_CHAIN_NAMES[@]}"}; do
            [[ -n "$chain_str" ]] && chain_str+=" → "
            chain_str+="$chain_name"
        done
        doctor_success "$leaf_name: chain resolves (${chain_str})"
    done

    if _doctor_resolve_from_leaf_no_clone; then
        CHAIN_NAMES=(${_DOCTOR_CHAIN_NAMES[@]+"${_DOCTOR_CHAIN_NAMES[@]}"})
        CHAIN_PATHS=(${_DOCTOR_CHAIN_PATHS[@]+"${_DOCTOR_CHAIN_PATHS[@]}"})

        local env=""
        env="$(detect_environment 2>/dev/null)" || true

        if [[ -n "$env" ]]; then
            doctor_success "Detected environment: $env"

            local i
            for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
                read_config "${CHAIN_PATHS[$i]}"
                if [[ ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && ! _is_declared_env "$env"; then
                    doctor_fail "${CHAIN_NAMES[$i]}: detected environment '$env' is not listed in DOTTY_ENVIRONMENTS"
                    continue
                fi

                if [[ -d "${CHAIN_PATHS[$i]}/$env/home" ]]; then
                    doctor_success "${CHAIN_NAMES[$i]}: $env overlay is declared"
                fi
            done
        else
            doctor_success "No environment detected"
        fi
    elif [[ $repo_count -gt 0 ]]; then
        doctor_fail "Could not resolve an active chain from the registered repos"
    fi

    echo ""
    if [[ $_DOCTOR_FAIL_COUNT -gt 0 ]]; then
        echo -e "${COLOR_RED}✖ dotty doctor found ${_DOCTOR_FAIL_COUNT} failure(s), ${_DOCTOR_WARN_COUNT} warning(s)${COLOR_NONE}" >&2
        return 1
    fi

    echo -e "${COLOR_GREEN}✔ dotty doctor found 0 failures, ${_DOCTOR_WARN_COUNT} warning(s)${COLOR_NONE}"
}

cmd_self_update() {
    if [[ ! -d "$DOTTY_DIR/.git" ]]; then
        die "Dotty is not a git repo at $DOTTY_DIR, cannot self-update."
    fi

    if [[ "${DOTTY_DRY_RUN:-false}" == "true" ]]; then
        info "[dry-run] Would pull dotty repo ($DOTTY_DIR)"
        return 0
    fi

    local before after
    before="$(cd "$DOTTY_DIR" && git rev-parse HEAD 2>/dev/null)" || die "Failed to read dotty revision"

    pull_if_clean "$DOTTY_DIR"

    after="$(cd "$DOTTY_DIR" && git rev-parse HEAD 2>/dev/null)" || die "Failed to read dotty revision"

    if [[ "$before" != "$after" ]]; then
        success "Dotty updated ($(echo "$before" | head -c 7)..$(echo "$after" | head -c 7))"
    else
        success "Already up to date."
    fi
}

cmd_shell_init() {
    local shell_name
    shell_name="$(basename "${SHELL:-}")"

    case "$shell_name" in
        zsh)
            cat <<'INIT'
dotty() {
    command dotty "$@"
    local _dotty_exit=$?
    if [[ $_dotty_exit -eq 0 && -o interactive && -f "${DOTTY_DIR:-$HOME/.dotty}/.needs-reload" ]]; then
        rm -f "${DOTTY_DIR:-$HOME/.dotty}/.needs-reload"
        echo -e "\033[32m✔ Shell config changed. Reloading...\033[0m"
        exec "$SHELL"
    fi
    return $_dotty_exit
}
INIT
            ;;
        bash)
            cat <<'INIT'
dotty() {
    command dotty "$@"
    local _dotty_exit=$?
    if [[ $_dotty_exit -eq 0 && $- == *i* && -f "${DOTTY_DIR:-$HOME/.dotty}/.needs-reload" ]]; then
        rm -f "${DOTTY_DIR:-$HOME/.dotty}/.needs-reload"
        echo -e "\033[32m✔ Shell config changed. Reloading...\033[0m"
        exec "$SHELL"
    fi
    return $_dotty_exit
}
INIT
            ;;
        *)
            die "Unsupported shell: $shell_name (expected zsh or bash)"
            ;;
    esac
}

cmd_help() {
    cat <<'EOF'
dotty - a dotfiles manager with overlay semantics

Usage: dotty [-v] [-n] <command> [args]

Commands:
  install [url-or-path]    Resolve chain, clone deps, link files, run hooks
  update [name]            Pull dotty and all repos, re-link, re-run hooks
  commands                 List repo-defined commands from the active chain
  run <name> [args]        Run a repo-defined command from .dotty/commands/
  cleanups [opts]          List one-shot cleanup task state
  self-update              Update dotty itself
  add <file> [--repo X]    Move a dotfile into a repo and symlink it back
  link [name]              Re-create symlinks only (skip pull and hooks)
  uninstall <name>         Remove a repo's symlinks, restore backups, unregister
  status                   Show repos, chain order, environment, and link health
  register <path> [name]   Register an already-cloned repo
  unregister <name>        Remove a repo from the registry
  files [repo]             List all managed files, grouped by repo
  trace <path>             Show which repo a file or directory comes from
  doctor                   Check registry, chain, hooks, commands, and cleanups
  check                    Warn if repos haven't been fetched recently
  shell-init               Output shell wrapper for auto-reload after changes
  guard [path]             Install pre-commit hook to block sensitive content
  guard-check [args]       Check staged or worktree content for guard patterns
  unguard [path]           Remove the dotty pre-commit hook
  help                     Show this help
  version                  Show version

Options:
  -v, --verbose            Show per-file skip messages (default: summary only)
  -n, --dry-run            Preview changes without modifying the filesystem

Pass-through:
  Use -- to stop dotty option parsing before repo-command args that reuse
  -v/--verbose or -n/--dry-run. Example: dotty run foo -- --verbose

Hook environment:
  DOTTY_REPO_DIR           Absolute path to the repo being processed
  DOTTY_ENV                Detected environment (empty if none)
  DOTTY_COMMAND            Command that invoked the hook (install or update)
  DOTTY_VERBOSE            "true" when -v/--verbose is set
  DOTTY_DRY_RUN            "true" when -n/--dry-run is set
  DOTTY_LIB                Path to hook utility library (source "$DOTTY_LIB")

Cleanup environment:
  DOTTY_CLEANUP_ID         Cleanup task id
  DOTTY_CLEANUP_STATE_DIR  Local state directory for the cleanup task

Repo command environment:
  DOTTY_COMMAND            "run" while executing a repo-defined command
  DOTTY_RUN_NAME           Resolved command name
  DOTTY_RUN_REPO           Absolute path to the repo providing the command
  DOTTY_ENV                Detected environment (empty if none)
  DOTTY_VERBOSE            "true" when -v/--verbose is set
  DOTTY_DRY_RUN            "true" when -n/--dry-run is set
  DOTTY_LIB                Path to command utility library (source "$DOTTY_LIB")

Guard:
  PUBLIC_CONTENT_GUARD_PATTERNS
                           Newline-separated patterns to block in commits
  PUBLIC_CONTENT_GUARD_PATTERN_FILE
                           Colon-separated pattern files to load
  PUBLIC_CONTENT_GUARD_SKIP=1
                           Disable guard checks

General:
  DOTTY_DIR                Base directory for dotty state (default: ~/.dotty)
  DOTTY_UPDATE_JOBS        Parallel git pulls for full-chain update (default: 1)

Serialization:
  install, update, link, uninstall, and self-update take a per-machine lock
  under DOTTY_DIR so overlapping runs wait instead of mutating shared state at
  the same time. Read-only commands and repo-defined dotty run commands are not
  serialized.
EOF
}

cmd_version() {
    echo "dotty $DOTTY_VERSION"
}

cmd_check() {
    # Skip if running inside a dotty hook (e.g., a hook spawned an interactive
    # shell that sources .zshrc and calls dotty check).
    [[ -n "${DOTTY_COMMAND:-}" ]] && return 0
    registry_init

    local threshold="${DOTTY_CHECK_THRESHOLD:-259200}"
    local now
    now="$(date +%s)"

    local seen=""
    local max_age=0

    while IFS='=' read -r _ repo_path; do
        [[ -z "$repo_path" ]] && continue
        case "$seen" in *"|${repo_path}|"*) continue ;; esac
        seen="${seen}|${repo_path}|"

        local fetch_head="$repo_path/.git/FETCH_HEAD"
        [[ -f "$fetch_head" ]] || continue

        local mtime
        if [[ "$OSTYPE" == darwin* ]]; then
            mtime="$(stat -f %m "$fetch_head" 2>/dev/null)" || continue
        else
            mtime="$(stat -c %Y "$fetch_head" 2>/dev/null)" || continue
        fi

        local age=$(( now - mtime ))
        (( age > max_age )) && max_age=$age
    done < "$DOTTY_REGISTRY"

    if (( max_age > threshold )); then
        local days=$(( max_age / 86400 ))
        warning "Dotfiles haven't been synced in ${days} days. Run 'dotty update' to refresh."
        return 1
    fi
}

# Main dispatch

main() {
    local args=()
    local passthrough=false
    for arg in "$@"; do
        if [[ "$passthrough" == "false" ]]; then
            case "$arg" in
                --)
                    passthrough=true
                    continue
                    ;;
                -v|--verbose)
                    DOTTY_VERBOSE=true
                    continue
                    ;;
                -n|--dry-run)
                    DOTTY_DRY_RUN=true
                    continue
                    ;;
            esac
        fi
        args+=("$arg")
    done
    set -- "${args[@]}"
    export DOTTY_VERBOSE
    export DOTTY_DRY_RUN

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        install)      _run_with_operation_lock "$cmd" cmd_install "$@" ;;
        update)       _run_with_operation_lock "$cmd" cmd_update "$@" ;;
        commands)     cmd_commands "$@" ;;
        run)          cmd_run "$@" ;;
        cleanups)     cmd_cleanups "$@" ;;
        self-update)  _run_with_operation_lock "$cmd" cmd_self_update "$@" ;;
        add)          cmd_add "$@" ;;
        link)         _run_with_operation_lock "$cmd" cmd_link "$@" ;;
        uninstall)    _run_with_operation_lock "$cmd" cmd_uninstall "$@" ;;
        status)       cmd_status "$@" ;;
        register)     cmd_register "$@" ;;
        unregister)   cmd_unregister "$@" ;;
        files)        cmd_files "$@" ;;
        trace)        cmd_trace "$@" ;;
        doctor)       cmd_doctor "$@" ;;
        check)        cmd_check "$@" ;;
        shell-init)   cmd_shell_init "$@" ;;
        guard)        cmd_guard "$@" ;;
        guard-check)  cmd_guard_check "$@" ;;
        unguard)      cmd_unguard "$@" ;;
        help|--help)  cmd_help ;;
        version|--version) cmd_version ;;
        *)            die "Unknown command: $cmd. Run 'dotty help' for usage." ;;
    esac
}

main "$@"
}
