#!/usr/bin/env bash
# dotty - a dotfiles manager with overlay semantics
{

set -euo pipefail

DOTTY_VERSION="0.3.0"
DOTTY_DIR="${DOTTY_DIR:-$HOME/.dotty}"
DOTTY_REGISTRY="$DOTTY_DIR/registry"
DOTTY_REPOS_DIR="$DOTTY_DIR/repos"
DOTTY_BACKUPS_DIR="$DOTTY_DIR/backups"
DOTTY_VERBOSE="${DOTTY_VERBOSE:-false}"
DOTTY_DRY_RUN="${DOTTY_DRY_RUN:-false}"
_DOTTY_CHANGES_MADE=false

# shellcheck source=lib/utils.sh
source "$(cd "$(dirname "$0")" && pwd)/lib/utils.sh"

# Registry

registry_init() {
    mkdir -p "$DOTTY_DIR" "$DOTTY_REPOS_DIR" "$DOTTY_BACKUPS_DIR"
    touch "$DOTTY_REGISTRY"
}

registry_get() {
    local name="$1"
    local line
    line="$(grep -m1 "^${name}=" "$DOTTY_REGISTRY" 2>/dev/null)" || return 1
    echo "${line#*=}"
}

registry_set() {
    local name="$1"
    local path="$2"

    if grep -q "^${name}=" "$DOTTY_REGISTRY" 2>/dev/null; then
        # Update existing entry (portable sed)
        local tmp="$DOTTY_REGISTRY.tmp"
        grep -v "^${name}=" "$DOTTY_REGISTRY" > "$tmp" || true
        echo "${name}=${path}" >> "$tmp"
        mv "$tmp" "$DOTTY_REGISTRY"
    else
        echo "${name}=${path}" >> "$DOTTY_REGISTRY"
    fi
}

registry_remove() {
    local name="$1"
    local tmp="$DOTTY_REGISTRY.tmp"
    grep -v "^${name}=" "$DOTTY_REGISTRY" > "$tmp" 2>/dev/null || true
    mv "$tmp" "$DOTTY_REGISTRY"
}

registry_names() {
    cut -d= -f1 "$DOTTY_REGISTRY" 2>/dev/null
}

# Config reading

# Find the config file for a repo. Returns 1 if not found.
_find_config() {
    local repo_dir="$1"
    if [[ -f "$repo_dir/.dotty/config" ]]; then
        echo "$repo_dir/.dotty/config"
    else
        return 1
    fi
}

# Find the hook script for a repo. Returns 1 if not found.
_find_hook() {
    local repo_dir="$1"
    if [[ -f "$repo_dir/.dotty/run.sh" ]]; then
        echo "$repo_dir/.dotty/run.sh"
    else
        return 1
    fi
}

# Find the commands directory for a repo. Returns 1 if not found.
_find_commands_dir() {
    local repo_dir="$1"
    if [[ -d "$repo_dir/.dotty/commands" ]]; then
        echo "$repo_dir/.dotty/commands"
    else
        return 1
    fi
}

# Returns true if the repo has a config file.
_has_config() {
    local repo_dir="$1"
    [[ -f "$repo_dir/.dotty/config" ]]
}

_reset_config_state() {
    DOTTY_NAME=""
    DOTTY_EXTENDS=()
    DOTTY_ENVIRONMENTS=()
    DOTTY_ENV_DETECT=""
    DOTTY_LINK_IGNORE=()
}

# Sets: DOTTY_NAME, DOTTY_EXTENDS, DOTTY_ENVIRONMENTS, DOTTY_ENV_DETECT
read_config() {
    local repo_dir="$1"
    local conf
    conf="$(_find_config "$repo_dir")" || die "No .dotty/config found in $repo_dir"

    _reset_config_state

    # shellcheck disable=SC1090
    source "$conf"

    [[ -n "$DOTTY_NAME" ]] || die "DOTTY_NAME is required in $conf"
}

_is_declared_env() {
    local name="$1"
    local env
    for env in ${DOTTY_ENVIRONMENTS[@]+"${DOTTY_ENVIRONMENTS[@]}"}; do
        [[ "$env" == "$name" ]] && return 0
    done
    return 1
}

# Chain resolution

CHAIN_NAMES=()
CHAIN_PATHS=()
_RESOLVING=()

resolve_chain() {
    local repo_dir
    repo_dir="$(cd "$1" && pwd)"

    read_config "$repo_dir"
    local name="$DOTTY_NAME"
    local -a extends=(${DOTTY_EXTENDS[@]+"${DOTTY_EXTENDS[@]}"})

    # Skip if already resolved (diamond dependency deduplication)
    for existing in ${CHAIN_NAMES[@]+"${CHAIN_NAMES[@]}"}; do
        [[ "$existing" == "$name" ]] && return 0
    done

    # Cycle detection (only tracks the current recursion stack)
    for r in ${_RESOLVING[@]+"${_RESOLVING[@]}"}; do
        [[ "$r" == "$name" ]] && die "Dependency cycle detected: $name"
    done
    _RESOLVING+=("$name")

    # Resolve parents first (so base repos come first in chain)
    for parent_url in ${extends[@]+"${extends[@]}"}; do
        local parent_dir
        parent_dir="$(ensure_repo "$parent_url")"
        resolve_chain "$parent_dir"
    done

    # Pop self from the resolving stack
    unset '_RESOLVING[${#_RESOLVING[@]}-1]'

    CHAIN_NAMES+=("$name")
    CHAIN_PATHS+=("$repo_dir")
}

resolve_chain_from_leaf() {
    registry_init

    local -a all_paths=()
    while IFS='=' read -r name rpath; do
        [[ -n "$name" && -d "$rpath" ]] && all_paths+=("$rpath")
    done < "$DOTTY_REGISTRY"

    [[ ${#all_paths[@]} -gt 0 ]] || die "No repos registered. Run 'dotty install' first."

    local best_len=0
    local -a best_names=() best_paths=()
    for rpath in "${all_paths[@]}"; do
        _has_config "$rpath" || continue
        CHAIN_NAMES=()
        CHAIN_PATHS=()
        _RESOLVING=()
        resolve_chain "$rpath" 2>/dev/null || true
        if [[ ${#CHAIN_NAMES[@]} -gt $best_len ]]; then
            best_len=${#CHAIN_NAMES[@]}
            best_names=(${CHAIN_NAMES[@]+"${CHAIN_NAMES[@]}"})
            best_paths=(${CHAIN_PATHS[@]+"${CHAIN_PATHS[@]}"})
        fi
    done
    CHAIN_NAMES=(${best_names[@]+"${best_names[@]}"})
    CHAIN_PATHS=(${best_paths[@]+"${best_paths[@]}"})
}

ensure_repo() {
    local source="$1"
    local target_dir="${2:-}"

    if [[ -d "$source" ]]; then
        (cd "$source" && pwd)
        return 0
    fi

    # Check registry — the repo name often matches the URL basename
    local url_basename
    url_basename="$(basename "$source" .git)"
    local registered_path
    registered_path="$(registry_get "$url_basename")" || true
    if [[ -n "$registered_path" && -d "$registered_path" ]] && _has_config "$registered_path"; then
        echo "$registered_path"
        return 0
    fi

    # Check if already cloned in DOTTY_REPOS_DIR
    for dir in "$DOTTY_REPOS_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local _conf
        _conf="$(_find_config "$dir")" || true
        if [[ -n "$_conf" ]]; then
            local found_name
            found_name="$(DOTTY_NAME=""; DOTTY_EXTENDS=(); DOTTY_ENVIRONMENTS=(); DOTTY_ENV_DETECT=""; source "$_conf"; echo "$DOTTY_NAME")"
            if [[ -n "$found_name" ]]; then
                local found_path
                found_path="$(registry_get "$found_name")" || true
                if [[ -n "$found_path" && -d "$found_path" ]]; then
                    echo "$found_path"
                    return 0
                fi
            fi
        fi
    done

    # If a target_dir was specified, check it before falling back to DOTTY_REPOS_DIR
    if [[ -n "$target_dir" && -d "$target_dir" ]]; then
        if _has_config "$target_dir"; then
            echo "$target_dir"
            return 0
        else
            die "$target_dir already exists but is not a dotty repo"
        fi
    fi

    local clone_name
    clone_name="$(basename "$source" .git)"
    local clone_dir="${target_dir:-$DOTTY_REPOS_DIR/$clone_name}"

    if [[ -d "$clone_dir" ]]; then
        echo "$clone_dir"
        return 0
    fi

    info "Cloning $source..." >&2
    git clone "$source" "$clone_dir" >&2 || die "Failed to clone $source"

    # Read its name and register
    local _clone_conf
    _clone_conf="$(_find_config "$clone_dir")" || true
    if [[ -n "$_clone_conf" ]]; then
        local cloned_name
        cloned_name="$(DOTTY_NAME=""; DOTTY_EXTENDS=(); DOTTY_ENVIRONMENTS=(); DOTTY_ENV_DETECT=""; source "$_clone_conf"; echo "$DOTTY_NAME")"
        if [[ -n "$cloned_name" ]]; then
            registry_set "$cloned_name" "$clone_dir"
        fi
    fi

    echo "$clone_dir"
}

# Environment detection

detect_environment() {
    local i
    for (( i=${#CHAIN_PATHS[@]}-1; i>=0; i-- )); do
        local dir="${CHAIN_PATHS[$i]}"
        local _econf
        _econf="$(_find_config "$dir")" || continue
        local env_detect
        env_detect="$(DOTTY_ENV_DETECT=""; DOTTY_EXTENDS=(); DOTTY_ENVIRONMENTS=(); source "$_econf"; echo "$DOTTY_ENV_DETECT")"
        if [[ -n "$env_detect" ]]; then
            local detected
            detected="$(eval "$env_detect")"
            if [[ -n "$detected" ]]; then
                echo "$detected"
                return 0
            fi
        fi
    done
}

# Core operations

pull_if_clean() {
    local dir="$1"
    if [[ ! -d "$dir/.git" ]]; then
        return 0
    fi

    local stashed=false
    if ! (cd "$dir" && git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null); then
        info "Stashing changes in $(basename "$dir")..."
        (cd "$dir" && git stash --quiet 2>/dev/null) && stashed=true
    fi

    local before after
    before="$(cd "$dir" && git rev-parse HEAD 2>/dev/null)" || true

    info "Pulling $(basename "$dir")..."
    if ! (cd "$dir" && git pull --rebase 2>/dev/null); then
        warning "Failed to pull $(basename "$dir")"
        (cd "$dir" && git rebase --abort 2>/dev/null) || true
    fi

    after="$(cd "$dir" && git rev-parse HEAD 2>/dev/null)" || true
    if [[ -n "$before" && -n "$after" && "$before" != "$after" ]]; then
        _DOTTY_CHANGES_MADE=true
    fi

    if [[ "$stashed" == "true" ]]; then
        (cd "$dir" && git stash pop --quiet 2>/dev/null) || warning "Failed to restore stashed changes in $(basename "$dir")"
    fi
}

# Pull the dotty repo itself before processing the chain. The script is
# wrapped in { ... } braces so bash reads it fully into memory before
# executing, making mid-run file changes safe. The updated script takes
# effect on the next invocation.
self_update() {
    # Non-git installs (e.g. manual copy) can't self-update.
    if [[ ! -d "$DOTTY_DIR/.git" ]]; then
        return 0
    fi

    if [[ "${DOTTY_DRY_RUN:-false}" == "true" ]]; then
        info "[dry-run] Would pull dotty repo ($DOTTY_DIR)"
        return 0
    fi

    pull_if_clean "$DOTTY_DIR"
}

_write_reload_marker() {
    if [[ "$_DOTTY_CHANGES_MADE" == "true" && "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
        touch "$DOTTY_DIR/.needs-reload"
    fi
}

process_repo() {
    local repo_dir="$1"
    local env="${2:-}"
    local command="${3:-}"

    read_config "$repo_dir"
    local name="$DOTTY_NAME"

    title "Processing $name"

    local do_env_overlay=false
    if [[ -n "$env" && ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]]; then
        if _is_declared_env "$env"; then
            [[ -d "$repo_dir/$env/home" ]] && do_env_overlay=true
        else
            warning "Detected environment '$env' not in DOTTY_ENVIRONMENTS for $name"
        fi
    fi

    # Clean up orphan symlinks (files removed from repo since last link)
    if [[ -d "$repo_dir/home" ]]; then
        cleanup_orphans "$repo_dir/home" "$HOME"
    fi
    if [[ "$do_env_overlay" == "true" ]]; then
        cleanup_orphans "$repo_dir/$env/home" "$HOME"
    fi

    # Symlink home/ → $HOME
    if [[ -d "$repo_dir/home" ]]; then
        info "Linking home/"
        create_symlinks_from_dir "$repo_dir/home" "$HOME"
    fi

    # Environment overlay: $env/home/ → $HOME
    if [[ "$do_env_overlay" == "true" ]]; then
        info "Linking $env/home/ overlay"
        create_symlinks_from_dir "$repo_dir/$env/home" "$HOME"
    fi

    # Run hook (non-fatal so later repos still process).
    # Hooks are skipped during "link" (symlink-only mode) and dry-run.
    if [[ "$command" != "link" && "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
        local hook_script
        hook_script="$(_find_hook "$repo_dir")" || true
        if [[ -n "$hook_script" && -x "$hook_script" ]]; then
            local hook_name
            hook_name="$(basename "$hook_script")"
            info "Running $hook_name"
            (
                export DOTTY_REPO_DIR="$repo_dir"
                export DOTTY_ENV="${env:-}"
                export DOTTY_COMMAND="${command:-}"
                export DOTTY_VERBOSE
                export DOTTY_LIB
                DOTTY_LIB="$(cd "$(dirname "$0")" && pwd)/lib/utils.sh"
                cd "$repo_dir"
                "$hook_script"
            ) || { warning "$hook_name failed in $name (exit $?)"; _HOOK_ERRORS+=("$name"); }
        elif [[ -n "$hook_script" ]]; then
            local hook_name
            hook_name="$(basename "$hook_script")"
            warning "$hook_name exists but is not executable in $name"
        fi
    fi
}

run_chain() {
    local pull="${1:-true}"
    local command="${2:-}"
    local env
    env="$(detect_environment)"

    if [[ -n "$env" ]]; then
        info "Detected environment: $env"
        export DOTTY_ENV="$env"
    fi

    _HOOK_ERRORS=()
    _LINK_FAIL_COUNT=0

    # Register all repos first so the registry is complete even if a hook fails.
    local i
    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        registry_set "${CHAIN_NAMES[$i]}" "${CHAIN_PATHS[$i]}"
    done

    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        local dir="${CHAIN_PATHS[$i]}"

        if [[ "$pull" == "true" && "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
            pull_if_clean "$dir"
        fi

        process_repo "$dir" "$env" "$command"
    done

    # Print error summary if anything went wrong
    _CHAIN_HAD_ERRORS=false
    if [[ ${#_HOOK_ERRORS[@]} -gt 0 ]]; then
        _CHAIN_HAD_ERRORS=true
        warning "Hook failures: ${_HOOK_ERRORS[*]}"
    fi
    if [[ $_LINK_FAIL_COUNT -gt 0 ]]; then
        _CHAIN_HAD_ERRORS=true
        warning "$_LINK_FAIL_COUNT symlink(s) failed to create"
    fi
}

# Commands

cmd_install() {
    local source="${1:-}"

    registry_init
    rm -f "$DOTTY_DIR/.needs-reload"
    _DOTTY_CHANGES_MADE=false

    if [[ -z "$source" ]]; then
        # No argument: re-run install on existing repos
        self_update
        resolve_chain_from_leaf
        run_chain "true" "install"
    else
        local repo_dir
        if [[ -d "$source" ]]; then
            repo_dir="$(cd "$source" && pwd)"
        else
            local source_basename
            source_basename="$(basename "$source" .git)"
            repo_dir="$(ensure_repo "$source" "$HOME/$source_basename")"
        fi

        # Resolve full chain
        CHAIN_NAMES=()
        CHAIN_PATHS=()
        _RESOLVING=()
        resolve_chain "$repo_dir"

        run_chain "true" "install"
    fi

    _write_reload_marker
    [[ "$_CHAIN_HAD_ERRORS" != "true" ]] && success "Install complete!"
    cmd_status
}

cmd_update() {
    local target="${1:-}"

    registry_init
    rm -f "$DOTTY_DIR/.needs-reload"
    _DOTTY_CHANGES_MADE=false
    self_update

    if [[ -n "$target" ]]; then
        # Update a single repo, but re-run full chain
        local path
        path="$(registry_get "$target")" || true
        [[ -n "$path" ]] || die "Unknown repo: $target"
        [[ -d "$path" ]] || die "Repo directory not found: $path"

        pull_if_clean "$path"

        # Resolve full chain from the leaf repo
        resolve_chain_from_leaf
        run_chain "false" "update"
    else
        resolve_chain_from_leaf
        run_chain "true" "update"
    fi

    _write_reload_marker
    [[ "$_CHAIN_HAD_ERRORS" != "true" ]] && success "Update complete!"
}

cmd_link() {
    local target="${1:-}"

    registry_init

    if [[ -n "$target" ]]; then
        local path
        path="$(registry_get "$target")" || true
        [[ -n "$path" ]] || die "Unknown repo: $target"

        CHAIN_NAMES=()
        CHAIN_PATHS=()
        _RESOLVING=()
        resolve_chain "$path"
    else
        resolve_chain_from_leaf
    fi

    local env
    env="$(detect_environment)"
    [[ -n "$env" ]] && info "Detected environment: $env"

    _HOOK_ERRORS=()
    _LINK_FAIL_COUNT=0

    local i
    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        local dir="${CHAIN_PATHS[$i]}"
        process_repo "$dir" "$env" "link"
    done

    if [[ $_LINK_FAIL_COUNT -gt 0 ]]; then
        warning "$_LINK_FAIL_COUNT symlink(s) failed to create"
    else
        success "Linking complete!"
    fi
}

_resolve_repo_command() {
    local target_name="$1"
    local i repo_dir="" repo_name="" candidate=""
    local found_repo_name="" found_repo_dir="" found_path="" found_executable="false"

    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        repo_dir="${CHAIN_PATHS[$i]}"
        repo_name="${CHAIN_NAMES[$i]}"
        candidate="$repo_dir/.dotty/commands/$target_name"

        if [[ -e "$candidate" ]]; then
            found_repo_name="$repo_name"
            found_repo_dir="$repo_dir"
            found_path="$candidate"

            if [[ -f "$candidate" && -x "$candidate" ]]; then
                found_executable="true"
            else
                found_executable="false"
            fi
        fi
    done

    [[ -n "$found_path" ]] || return 1
    printf '%s\t%s\t%s\t%s\n' "$found_repo_name" "$found_repo_dir" "$found_path" "$found_executable"
}

_resolved_repo_command_records() {
    local -a names=() repo_names=() repo_dirs=() paths=() executable=()
    local i repo_dir="" repo_name="" commands_dir="" item="" name="" index=-1

    for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
        repo_dir="${CHAIN_PATHS[$i]}"
        repo_name="${CHAIN_NAMES[$i]}"
        commands_dir="$(_find_commands_dir "$repo_dir")" || continue

        for item in "$commands_dir"/*; do
            [[ -e "$item" ]] || continue
            [[ -f "$item" ]] || continue

            name="$(basename "$item")"
            [[ "$name" == .* ]] && continue

            index=-1
            local existing_index
            for existing_index in "${!names[@]}"; do
                if [[ "${names[$existing_index]}" == "$name" ]]; then
                    index="$existing_index"
                    break
                fi
            done

            if (( index < 0 )); then
                names+=("$name")
                repo_names+=("")
                repo_dirs+=("")
                paths+=("")
                executable+=("false")
                index=$((${#names[@]} - 1))
            fi

            names[$index]="$name"
            repo_names[$index]="$repo_name"
            repo_dirs[$index]="$repo_dir"
            paths[$index]="$item"
            if [[ -x "$item" ]]; then
                executable[$index]="true"
            else
                executable[$index]="false"
            fi
        done
    done

    local output=""
    for i in "${!names[@]}"; do
        [[ "${executable[$i]}" == "true" ]] || continue
        output+="${names[$i]}"$'\t'"${repo_names[$i]}"$'\t'"${repo_dirs[$i]}"$'\t'"${paths[$i]}"$'\n'
    done

    printf '%s' "$output" | LC_ALL=C sort
}

cmd_commands() {
    [[ $# -eq 0 ]] || die "Usage: dotty commands"

    registry_init
    resolve_chain_from_leaf

    local records=""
    records="$(_resolved_repo_command_records)"
    [[ -n "$records" ]] || return 0

    while IFS=$'\t' read -r name repo_name _repo_dir _path || [[ -n "${name:-}${repo_name:-}" ]]; do
        [[ -n "${name}" ]] || continue
        printf '%s\t%s\n' "$name" "$repo_name"
    done <<< "$records"
}

cmd_run() {
    local target_name="${1:-}"
    [[ -n "$target_name" ]] || die "Usage: dotty run <name> [args]"
    shift || true

    registry_init
    resolve_chain_from_leaf

    local repo_name="" repo_dir="" command_path="" executable="false"
    if ! IFS=$'\t' read -r repo_name repo_dir command_path executable < <(_resolve_repo_command "$target_name"); then
        die "Unknown repo-defined command: $target_name"
    fi

    [[ "$executable" == "true" ]] || die "Command '$target_name' exists but is not executable: $command_path"

    if [[ "${DOTTY_DRY_RUN:-false}" == "true" ]]; then
        info "[dry-run] Would run command '$target_name' from $repo_name"
        return 0
    fi

    local env=""
    env="$(detect_environment)"

    export DOTTY_COMMAND="run"
    export DOTTY_RUN_NAME="$target_name"
    export DOTTY_RUN_REPO="$repo_dir"
    export DOTTY_ENV="${env:-}"
    export DOTTY_VERBOSE
    export DOTTY_DRY_RUN
    export DOTTY_LIB
    DOTTY_LIB="$(cd "$(dirname "$0")" && pwd)/lib/utils.sh"

    cd "$repo_dir"
    exec "$command_path" "$@"
}

cmd_uninstall() {
    local target_name="${1:-}"
    [[ -n "$target_name" ]] || die "Usage: dotty uninstall <name>"

    registry_init

    local target_path
    target_path="$(registry_get "$target_name")" || true
    [[ -n "$target_path" ]] || die "Unknown repo: $target_name"

    read_config "$target_path"

    title "Uninstalling $target_name"

    # Remove symlinks from home/
    if [[ -d "$target_path/home" ]]; then
        remove_repo_symlinks "$target_path/home" "$HOME"
    fi

    # Remove symlinks from environment overlay
    local env=""
    if [[ ${#CHAIN_PATHS[@]} -eq 0 ]]; then
        # Resolve chain so we can detect environment
        CHAIN_NAMES=()
        CHAIN_PATHS=()
        _RESOLVING=()
        resolve_chain_from_leaf 2>/dev/null || true
    fi
    env="$(detect_environment 2>/dev/null)" || true
    if [[ -n "$env" && ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && _is_declared_env "$env"; then
        if [[ -d "$target_path/$env/home" ]]; then
            remove_repo_symlinks "$target_path/$env/home" "$HOME"
        fi
    fi

    local summary="${_UNLINK_COUNT} symlink(s) removed"
    if [[ $_RESTORE_COUNT -gt 0 ]]; then
        summary+=", ${_RESTORE_COUNT} file(s) restored from backup"
    fi
    info "$summary"

    # Unregister
    if [[ "${DOTTY_DRY_RUN:-false}" != "true" ]]; then
        registry_remove "$target_name"
    else
        info "[dry-run] Would unregister $target_name"
    fi

    success "Uninstalled $target_name"
}

cmd_add() {
    local file=""
    local repo_name=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo)
                [[ $# -ge 2 ]] || die "Usage: dotty add <file> [--repo <name>]"
                repo_name="$2"
                shift 2
                ;;
            --repo=*)
                repo_name="${1#--repo=}"
                shift
                ;;
            *)
                file="$1"
                shift
                ;;
        esac
    done

    [[ -n "$file" ]] || die "Usage: dotty add <file> [--repo <name>]"
    [[ -e "$file" ]] || die "File not found: $file"
    [[ -L "$file" ]] && die "Already a symlink: $file"

    registry_init

    local abs_file
    abs_file="$(cd "$(dirname "$file")" && pwd)/$(basename "$file")"

    local repo_path=""
    if [[ -n "$repo_name" ]]; then
        repo_path="$(registry_get "$repo_name")" || true
        [[ -n "$repo_path" ]] || die "Unknown repo: $repo_name"
    else
        local count
        count="$(wc -l < "$DOTTY_REGISTRY" | tr -d ' ')"

        if [[ "$count" -eq 0 ]]; then
            die "No repos registered. Run 'dotty install' first."
        elif [[ "$count" -eq 1 ]]; then
            repo_name="$(cut -d= -f1 "$DOTTY_REGISTRY")"
            repo_path="$(cut -d= -f2- "$DOTTY_REGISTRY")"
        else
            echo "Multiple repos registered. Which one?"
            local i=1
            while IFS='=' read -r name rpath; do
                echo "  $i) $name ($rpath)"
                i=$((i + 1))
            done < "$DOTTY_REGISTRY"
            echo -n "Choice: "
            read -r choice
            repo_name="$(sed -n "${choice}p" "$DOTTY_REGISTRY" | cut -d= -f1)"
            repo_path="$(sed -n "${choice}p" "$DOTTY_REGISTRY" | cut -d= -f2-)"
        fi
    fi

    [[ -d "$repo_path" ]] || die "Repo directory not found: $repo_path"

    local rel_path="${abs_file#"$HOME"/}"
    [[ "$rel_path" != "$abs_file" ]] || die "File must be under \$HOME: $abs_file"
    local dest="$repo_path/home/$rel_path"
    [[ ! -e "$dest" && ! -L "$dest" ]] || die "Target already exists in repo: $dest"

    mkdir -p "$(dirname "$dest")"
    mv "$abs_file" "$dest"
    ln -s "$dest" "$abs_file"

    success "Moved: ~/$rel_path → $repo_name/home/$rel_path"
    success "Linked: ~/$rel_path"
    echo ""
    info "Don't forget to commit the new file:"
    echo -e "${COLOR_DIM}cd $repo_path && git add home/$rel_path${COLOR_NONE}"
}

cmd_status() {
    registry_init

    title "dotty status"

    local count=0
    local repos=()
    while IFS='=' read -r name rpath; do
        [[ -n "$name" ]] || continue
        repos+=("$name=$rpath")
        count=$((count + 1))
    done < "$DOTTY_REGISTRY"

    if [[ $count -eq 0 ]]; then
        info "No repos registered."
        return 0
    fi

    resolve_chain_from_leaf

    if [[ ${#CHAIN_NAMES[@]} -gt 0 ]]; then
        local chain_str=""
        for (( i=0; i<${#CHAIN_NAMES[@]}; i++ )); do
            [[ -n "$chain_str" ]] && chain_str+=" → "
            chain_str+="${CHAIN_NAMES[$i]}"
        done
        echo -e "Chain: ${COLOR_GREEN}$chain_str${COLOR_NONE}"
    fi

    local env=""
    if [[ ${#CHAIN_PATHS[@]} -gt 0 ]]; then
        env="$(detect_environment 2>/dev/null)" || true
    fi
    if [[ -n "$env" ]]; then
        echo -e "Env:   ${COLOR_GREEN}$env${COLOR_NONE}"

        local overlay_repos=()
        for (( i=0; i<${#CHAIN_PATHS[@]}; i++ )); do
            if [[ -d "${CHAIN_PATHS[$i]}/$env/home" ]]; then
                if _has_config "${CHAIN_PATHS[$i]}"; then
                    read_config "${CHAIN_PATHS[$i]}"
                    if [[ ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && _is_declared_env "$env"; then
                        overlay_repos+=("${CHAIN_NAMES[$i]}")
                    fi
                fi
            fi
        done
        if [[ ${#overlay_repos[@]} -gt 0 ]]; then
            echo -e "         ${COLOR_DIM}overlays: ${overlay_repos[*]}${COLOR_NONE}"
        fi
    fi

    echo ""

    for entry in "${repos[@]}"; do
        local name="${entry%%=*}"
        local rpath="${entry#*=}"

        local status_icon="?"
        local status_text="unknown"
        if [[ -d "$rpath/.git" ]]; then
            if (cd "$rpath" && git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null); then
                status_icon="${COLOR_GREEN}✓${COLOR_NONE}"
                status_text="clean"
            else
                status_icon="${COLOR_YELLOW}●${COLOR_NONE}"
                status_text="modified"
            fi
        elif [[ -d "$rpath" ]]; then
            status_icon="${COLOR_DIM}-${COLOR_NONE}"
            status_text="not a git repo"
        else
            status_icon="${COLOR_RED}✗${COLOR_NONE}"
            status_text="missing"
        fi

        # Count symlink health
        local linked=0 overridden=0 not_linked=0
        _FILE_LINES=()
        if _has_config "$rpath"; then
            read_config "$rpath"
        else
            _reset_config_state
        fi
        _files_walk "$rpath/home" "" "$name"
        if [[ -n "$env" && -d "$rpath/$env/home" ]]; then
            if [[ ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && _is_declared_env "$env"; then
                _files_walk "$rpath/$env/home" "" "$name"
            fi
        fi
        for fl in ${_FILE_LINES[@]+"${_FILE_LINES[@]}"}; do
            case "${fl%%|*}" in
                linked)     linked=$((linked + 1)) ;;
                overridden) overridden=$((overridden + 1)) ;;
                not_linked) not_linked=$((not_linked + 1)) ;;
            esac
        done

        local link_summary="${linked} linked"
        if [[ $overridden -gt 0 ]]; then
            link_summary+=", ${overridden} overridden"
        fi
        if [[ $not_linked -gt 0 ]]; then
            link_summary+=", ${not_linked} unlinked"
        fi

        echo -e "$status_icon $name ${COLOR_DIM}($rpath) [$status_text] [$link_summary]${COLOR_NONE}"
    done
}

cmd_register() {
    local path="${1:-}"
    local name="${2:-}"

    [[ -n "$path" ]] || die "Usage: dotty register <path> [name]"

    registry_init

    [[ -d "$path" ]] || die "Directory not found: $path"
    path="$(cd "$path" && pwd)"

    if [[ -z "$name" ]]; then
        local conf
        conf="$(_find_config "$path")" || die "No .dotty/config found and no name provided"
        name="$(DOTTY_NAME=""; source "$conf"; echo "$DOTTY_NAME")"
        [[ -n "$name" ]] || die "DOTTY_NAME not set in $conf"
    fi

    registry_set "$name" "$path"
    success "Registered $name → $path"
}

cmd_unregister() {
    local name="${1:-}"
    [[ -n "$name" ]] || die "Usage: dotty unregister <name>"

    registry_init

    local path
    path="$(registry_get "$name")" || true
    [[ -n "$path" ]] || die "Unknown repo: $name"

    registry_remove "$name"
    success "Unregistered $name"
}

_resolve_script_dir() {
    # Resolve through symlinks so this works when invoked via ~/.dotty/bin/dotty.
    local script="$0"
    while [[ -L "$script" ]]; do
        local target
        target="$(readlink "$script")"
        if [[ "$target" == /* ]]; then
            script="$target"
        else
            script="$(dirname "$script")/$target"
        fi
    done
    (cd "$(dirname "$script")" && pwd)
}

_guard_hook_path() {
    local script_dir
    script_dir="$(_resolve_script_dir)"

    if [[ -f "$script_dir/hooks/pre-commit" ]]; then
        echo "$script_dir/hooks/pre-commit"
    else
        die "Cannot find hooks/pre-commit relative to dotty script ($script_dir)"
    fi
}

_guard_is_ours() {
    local hook="$1"
    [[ -f "$hook" ]] && grep -q "dotty guard" "$hook" 2>/dev/null
}

_guard_pattern_hint() {
    if [[ -n "${DOTTY_GUARD_PATTERNS:-}" ]]; then
        local count=0
        while IFS= read -r line; do
            line="${line## }"
            line="${line%% }"
            [[ -z "$line" || "$line" == \#* ]] && continue
            count=$((count + 1))
        done <<< "$DOTTY_GUARD_PATTERNS"
        info "DOTTY_GUARD_PATTERNS has $count pattern(s) configured."
    else
        warning "DOTTY_GUARD_PATTERNS is not set. The hook will be a no-op until you export it."
    fi
}

cmd_guard() {
    local target="${1:-.}"

    [[ -d "$target" ]] || die "Directory not found: $target"
    target="$(cd "$target" && pwd)"
    [[ -d "$target/.git" ]] || die "Not a git repository: $target"

    local hook_dest="$target/.git/hooks/pre-commit"
    local hook_src
    hook_src="$(_guard_hook_path)"

    if [[ -f "$hook_dest" ]]; then
        if _guard_is_ours "$hook_dest"; then
            # Always re-copy to pick up hook updates.
            cp "$hook_src" "$hook_dest"
            chmod +x "$hook_dest"
            success "Guard hook updated in $target"
            _guard_pattern_hint
            return 0
        fi

        warning "A pre-commit hook already exists in $target"
        echo -n "  Overwrite it? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy]$ ]] || { info "Aborted."; return 1; }
    fi

    mkdir -p "$target/.git/hooks"
    cp "$hook_src" "$hook_dest"
    chmod +x "$hook_dest"

    success "Guard hook installed in $target"
    _guard_pattern_hint
}

cmd_unguard() {
    local target="${1:-.}"

    [[ -d "$target" ]] || die "Directory not found: $target"
    target="$(cd "$target" && pwd)"
    [[ -d "$target/.git" ]] || die "Not a git repository: $target"

    local hook="$target/.git/hooks/pre-commit"

    if [[ ! -f "$hook" ]]; then
        info "No pre-commit hook found in $target"
        return 0
    fi

    if ! _guard_is_ours "$hook"; then
        warning "The pre-commit hook in $target was not installed by dotty."
        echo -n "  Remove it anyway? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy]$ ]] || { info "Aborted."; return 1; }
    fi

    rm "$hook"
    success "Guard hook removed from $target"
}

_FILE_LINES=()

# Check if a $HOME path is managed by dotty, either as a direct symlink
# or via a parent directory that is symlinked into a repo.
_is_managed() {
    local home_path="$1"
    local source_item="$2"

    # Direct symlink pointing to the source item
    if [[ -L "$home_path" ]]; then
        local link_target
        link_target="$(readlink "$home_path")"
        if [[ "$link_target" == "$source_item" ]]; then
            echo "linked"
            return 0
        else
            echo "overridden"
            return 0
        fi
    fi

    # Check if a parent directory is a symlink into a repo
    local check="$home_path"
    while [[ "$check" != "$HOME" && "$check" != "/" ]]; do
        check="$(dirname "$check")"
        if [[ -L "$check" ]]; then
            # Parent is a symlink — check if the file is accessible through it
            if [[ -e "$home_path" ]]; then
                echo "linked"
                return 0
            fi
            break
        fi
    done

    echo "not_linked"
}

_files_walk() {
    local source_dir="$1"
    local prefix="$2"
    local repo_name="$3"

    [[ -d "$source_dir" ]] || return 0

    local item
    for item in "$source_dir"/* "$source_dir"/.*; do
        [[ -e "$item" ]] || continue
        local name
        name="$(basename "$item")"
        [[ "$name" == "." || "$name" == ".." ]] && continue
        should_exclude "$name" && continue

        local rel="${prefix:+$prefix/}$name"
        _is_link_ignored "$rel" && continue
        _is_gitignored "$item" && continue

        local home_path="$HOME/$rel"

        if [[ -d "$item" && ! -L "$item" ]]; then
            _files_walk "$item" "$rel" "$repo_name"
        else
            local status
            status="$(_is_managed "$home_path" "$item")"
            _FILE_LINES+=("$status|$rel|$repo_name")
        fi
    done
}

cmd_files() {
    local filter_repo="${1:-}"

    registry_init

    local -a all_names=()
    local -a all_paths=()
    while IFS='=' read -r name rpath; do
        [[ -n "$name" ]] || continue
        if [[ -n "$filter_repo" && "$name" != "$filter_repo" ]]; then
            continue
        fi
        all_names+=("$name")
        all_paths+=("$rpath")
    done < "$DOTTY_REGISTRY"

    if [[ ${#all_names[@]} -eq 0 ]]; then
        if [[ -n "$filter_repo" ]]; then
            die "Unknown repo: $filter_repo"
        fi
        info "No repos registered."
        return 0
    fi

    # Detect environment for overlay scanning
    local env=""
    env="$(detect_environment 2>/dev/null)" || true

    _FILE_LINES=()

    for (( i=0; i<${#all_names[@]}; i++ )); do
        local name="${all_names[$i]}"
        local rpath="${all_paths[$i]}"

        if _has_config "$rpath"; then
            read_config "$rpath"
        else
            _reset_config_state
        fi
        _files_walk "$rpath/home" "" "$name"

        # Environment overlay
        if [[ -n "$env" && -d "$rpath/$env/home" ]]; then
            if [[ ${#DOTTY_ENVIRONMENTS[@]} -gt 0 ]] && _is_declared_env "$env"; then
                _files_walk "$rpath/$env/home" "" "$name"
            fi
        fi
    done

    if [[ ${#_FILE_LINES[@]} -eq 0 ]]; then
        info "No managed files found."
        return 0
    fi

    # Group by repo, show status
    local current_repo=""
    # Sort by repo name then path
    local -a sorted
    IFS=$'\n' sorted=($(printf '%s\n' ${_FILE_LINES[@]+"${_FILE_LINES[@]}"} | sort -t'|' -k3,3 -k2,2))
    unset IFS

    for line in "${sorted[@]}"; do
        local status="${line%%|*}"
        local rest="${line#*|}"
        local rel="${rest%%|*}"
        local repo="${rest#*|}"

        if [[ "$repo" != "$current_repo" ]]; then
            [[ -n "$current_repo" ]] && echo ""
            title "$repo"
            current_repo="$repo"
        fi

        case "$status" in
            linked)
                echo -e "${COLOR_GREEN}✓ ~/$rel${COLOR_NONE}"
                ;;
            overridden)
                echo -e "${COLOR_DIM}○ ~/$rel (overridden)${COLOR_NONE}"
                ;;
            not_linked)
                echo -e "${COLOR_YELLOW}● ~/$rel (not linked)${COLOR_NONE}"
                ;;
        esac
    done
}

cmd_trace() {
    local target="${1:-}"
    [[ -n "$target" ]] || die "Usage: dotty trace <path>"

    registry_init

    # Expand ~ and resolve to absolute path (but don't follow symlinks yet)
    if [[ "$target" == "~/"* ]]; then
        target="$HOME/${target#\~/}"
    fi
    if [[ "$target" != /* ]]; then
        target="$(pwd)/$target"
    fi

    if [[ ! -e "$target" && ! -L "$target" ]]; then
        die "Path does not exist: $target"
    fi

    local display="~${target#"$HOME"}"

    if [[ ! -L "$target" ]]; then
        # Not a symlink — check if it's a directory with dotty-managed contents
        if [[ -d "$target" ]]; then
            local found=0
            local item
            for item in "$target"/* "$target"/.*; do
                [[ -e "$item" || -L "$item" ]] || continue
                local iname
                iname="$(basename "$item")"
                [[ "$iname" == "." || "$iname" == ".." ]] && continue
                [[ -L "$item" ]] || continue

                local link_target
                link_target="$(readlink "$item")"

                while IFS='=' read -r name rpath; do
                    [[ -n "$name" ]] || continue
                    if [[ "$link_target" == "$rpath/home/"* || "$link_target" == "$rpath/"*/home/* ]]; then
                        local rel="${link_target#"$rpath"/}"
                        echo -e "~${item#"$HOME"}  →  ${COLOR_GREEN}$name${COLOR_NONE} ($rel)"
                        found=$((found + 1))
                    fi
                done < "$DOTTY_REGISTRY"
            done
            if [[ $found -eq 0 ]]; then
                info "$display is a directory not managed by dotty"
            fi
        else
            info "$display is not a symlink (not managed by dotty)"
        fi
        return 0
    fi

    # It's a symlink — resolve and match against repos
    local link_target
    link_target="$(readlink "$target")"

    local matched=0
    while IFS='=' read -r name rpath; do
        [[ -n "$name" ]] || continue
        if [[ "$link_target" == "$rpath/home/"* || "$link_target" == "$rpath/"*/home/* ]]; then
            local rel="${link_target#"$rpath"/}"
            echo -e "$display  →  ${COLOR_GREEN}$name${COLOR_NONE} ($rel)"
            matched=1
            break
        fi
    done < "$DOTTY_REGISTRY"

    if [[ $matched -eq 0 ]]; then
        # Symlink exists but doesn't point into any registered repo
        info "$display → $link_target (not managed by dotty)"
    fi
}

cmd_self_update() {
    if [[ ! -d "$DOTTY_DIR/.git" ]]; then
        die "Dotty is not a git repo at $DOTTY_DIR, cannot self-update."
    fi

    if [[ "${DOTTY_DRY_RUN:-false}" == "true" ]]; then
        info "[dry-run] Would pull dotty repo ($DOTTY_DIR)"
        return 0
    fi

    local before after
    before="$(cd "$DOTTY_DIR" && git rev-parse HEAD 2>/dev/null)" || die "Failed to read dotty revision"

    pull_if_clean "$DOTTY_DIR"

    after="$(cd "$DOTTY_DIR" && git rev-parse HEAD 2>/dev/null)" || die "Failed to read dotty revision"

    if [[ "$before" != "$after" ]]; then
        success "Dotty updated ($(echo "$before" | head -c 7)..$(echo "$after" | head -c 7))"
    else
        success "Already up to date."
    fi
}

cmd_shell_init() {
    local shell_name
    shell_name="$(basename "${SHELL:-}")"

    case "$shell_name" in
        zsh)
            cat <<'INIT'
dotty() {
    command dotty "$@"
    local _dotty_exit=$?
    if [[ $_dotty_exit -eq 0 && -o interactive && -f "${DOTTY_DIR:-$HOME/.dotty}/.needs-reload" ]]; then
        rm -f "${DOTTY_DIR:-$HOME/.dotty}/.needs-reload"
        echo -e "\033[32m✔ Shell config changed. Reloading...\033[0m"
        exec "$SHELL"
    fi
    return $_dotty_exit
}
INIT
            ;;
        bash)
            cat <<'INIT'
dotty() {
    command dotty "$@"
    local _dotty_exit=$?
    if [[ $_dotty_exit -eq 0 && $- == *i* && -f "${DOTTY_DIR:-$HOME/.dotty}/.needs-reload" ]]; then
        rm -f "${DOTTY_DIR:-$HOME/.dotty}/.needs-reload"
        echo -e "\033[32m✔ Shell config changed. Reloading...\033[0m"
        exec "$SHELL"
    fi
    return $_dotty_exit
}
INIT
            ;;
        *)
            die "Unsupported shell: $shell_name (expected zsh or bash)"
            ;;
    esac
}

cmd_help() {
    cat <<'EOF'
dotty - a dotfiles manager with overlay semantics

Usage: dotty [-v] [-n] <command> [args]

Commands:
  install [url-or-path]    Resolve chain, clone deps, link files, run hooks
  update [name]            Pull dotty and all repos, re-link, re-run hooks
  commands                 List repo-defined commands from the active chain
  run <name> [args]        Run a repo-defined command from .dotty/commands/
  self-update              Update dotty itself
  add <file> [--repo X]    Move a dotfile into a repo and symlink it back
  link [name]              Re-create symlinks only (skip pull and hooks)
  uninstall <name>         Remove a repo's symlinks, restore backups, unregister
  status                   Show repos, chain order, environment, and link health
  register <path> [name]   Register an already-cloned repo
  unregister <name>        Remove a repo from the registry
  files [repo]             List all managed files, grouped by repo
  trace <path>             Show which repo a file or directory comes from
  check                    Warn if repos haven't been fetched recently
  shell-init               Output shell wrapper for auto-reload after changes
  guard [path]             Install pre-commit hook to block sensitive content
  unguard [path]           Remove the dotty pre-commit hook
  help                     Show this help
  version                  Show version

Options:
  -v, --verbose            Show per-file skip messages (default: summary only)
  -n, --dry-run            Preview changes without modifying the filesystem

Pass-through:
  Use -- to stop dotty option parsing before repo-command args that reuse
  -v/--verbose or -n/--dry-run. Example: dotty run foo -- --verbose

Hook environment:
  DOTTY_REPO_DIR           Absolute path to the repo being processed
  DOTTY_ENV                Detected environment (empty if none)
  DOTTY_COMMAND            Command that invoked the hook (install or update)
  DOTTY_VERBOSE            "true" when -v/--verbose is set
  DOTTY_LIB                Path to hook utility library (source "$DOTTY_LIB")

Repo command environment:
  DOTTY_COMMAND            "run" while executing a repo-defined command
  DOTTY_RUN_NAME           Resolved command name
  DOTTY_RUN_REPO           Absolute path to the repo providing the command
  DOTTY_ENV                Detected environment (empty if none)
  DOTTY_VERBOSE            "true" when -v/--verbose is set
  DOTTY_LIB                Path to command utility library (source "$DOTTY_LIB")

Guard:
  DOTTY_GUARD_PATTERNS     Newline-separated patterns to block in commits

General:
  DOTTY_DIR                Base directory for dotty state (default: ~/.dotty)
EOF
}

cmd_version() {
    echo "dotty $DOTTY_VERSION"
}

cmd_check() {
    # Skip if running inside a dotty hook (e.g., a hook spawned an interactive
    # shell that sources .zshrc and calls dotty check).
    [[ -n "${DOTTY_COMMAND:-}" ]] && return 0
    registry_init

    local threshold="${DOTTY_CHECK_THRESHOLD:-86400}"
    local now
    now="$(date +%s)"

    local seen=""
    local max_age=0

    while IFS='=' read -r _ repo_path; do
        [[ -z "$repo_path" ]] && continue
        case "$seen" in *"|${repo_path}|"*) continue ;; esac
        seen="${seen}|${repo_path}|"

        local fetch_head="$repo_path/.git/FETCH_HEAD"
        [[ -f "$fetch_head" ]] || continue

        local mtime
        if [[ "$OSTYPE" == darwin* ]]; then
            mtime="$(stat -f %m "$fetch_head" 2>/dev/null)" || continue
        else
            mtime="$(stat -c %Y "$fetch_head" 2>/dev/null)" || continue
        fi

        local age=$(( now - mtime ))
        (( age > max_age )) && max_age=$age
    done < "$DOTTY_REGISTRY"

    if (( max_age > threshold )); then
        local days=$(( max_age / 86400 ))
        warning "Dotfiles haven't been synced in ${days} days. Run 'dotty update' to refresh."
        return 1
    fi
}

# Main dispatch

main() {
    local args=()
    local passthrough=false
    for arg in "$@"; do
        if [[ "$passthrough" == "false" ]]; then
            case "$arg" in
                --)
                    passthrough=true
                    continue
                    ;;
                -v|--verbose)
                    DOTTY_VERBOSE=true
                    continue
                    ;;
                -n|--dry-run)
                    DOTTY_DRY_RUN=true
                    continue
                    ;;
            esac
        fi
        args+=("$arg")
    done
    set -- "${args[@]}"
    export DOTTY_VERBOSE
    export DOTTY_DRY_RUN

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        install)      cmd_install "$@" ;;
        update)       cmd_update "$@" ;;
        commands)     cmd_commands "$@" ;;
        run)          cmd_run "$@" ;;
        self-update)  cmd_self_update "$@" ;;
        add)          cmd_add "$@" ;;
        link)         cmd_link "$@" ;;
        uninstall)    cmd_uninstall "$@" ;;
        status)       cmd_status "$@" ;;
        register)     cmd_register "$@" ;;
        unregister)   cmd_unregister "$@" ;;
        files)        cmd_files "$@" ;;
        trace)        cmd_trace "$@" ;;
        check)        cmd_check "$@" ;;
        shell-init)   cmd_shell_init "$@" ;;
        guard)        cmd_guard "$@" ;;
        unguard)      cmd_unguard "$@" ;;
        help|--help)  cmd_help ;;
        version|--version) cmd_version ;;
        *)            die "Unknown command: $cmd. Run 'dotty help' for usage." ;;
    esac
}

main "$@"
}
